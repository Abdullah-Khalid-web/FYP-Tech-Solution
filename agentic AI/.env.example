# Agentic AI Service Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (Required)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Model (Optional - defaults to gpt-4-turbo-preview)
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.1

# Backend API Configuration (provided by backend team)
BACKEND_API_BASE_URL=http://localhost:3000/api
BACKEND_API_TIMEOUT=30

# Shop Configuration (multi-tenant support)
DEFAULT_SHOP_ID=24

# Agent Settings
MAX_RETRIES=3
VERBOSE_LOGGING=true
