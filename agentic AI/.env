# Agentic AI Service Configuration
# Copy this file to .env and fill in your values

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (Groq)
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1

# Backend API Configuration (provided by backend team)
BACKEND_API_BASE_URL=http://localhost:3000/api
BACKEND_API_TIMEOUT=30

# Shop Configuration (multi-tenant support)
DEFAULT_SHOP_ID=24

# Agent Settings
MAX_RETRIES=3
VERBOSE_LOGGING=true

# Security (must match backend's AI_SERVICE_SECRET)
AI_SERVICE_SECRET=managehub-ai-secret-2026
ALLOWED_ORIGINS=http://localhost:3000
