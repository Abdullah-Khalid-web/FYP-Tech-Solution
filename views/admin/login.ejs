<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - Manage Hub</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Plus+Jakarta+Sans:wght@400;500;700&display=swap');

        /* Override container for auth pages */
        body {
            background-color: #f8fafc;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
        }

        /* Background elements */
        .auth-bg-shape1 {
            position: absolute;
            top: -100px;
            left: -100px;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(15, 23, 42, 0.15) 0%, rgba(255,255,255,0) 70%);
            z-index: 0;
            animation: floatShape 10s ease-in-out infinite alternate;
        }

        .auth-bg-shape2 {
            position: absolute;
            bottom: -100px;
            right: -100px;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(14,165,233,0.15) 0%, rgba(255,255,255,0) 70%);
            z-index: 0;
            animation: floatShape 15s ease-in-out infinite alternate-reverse;
        }

        @keyframes floatShape {
            0% { transform: translateY(0); }
            100% { transform: translateY(30px); }
        }

        .auth-card {
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(0,0,0,0.05);
            width: 100%;
            max-width: 450px;
            padding: 3rem;
            position: relative;
            z-index: 10;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .auth-header h2 {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            color: #0f172a;
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .auth-header p {
            color: #64748b;
            font-size: 0.95rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .modern-label {
            font-weight: 600;
            color: #4b5563;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
            display: block;
        }

        .modern-input {
            width: 100%;
            padding: 0.85rem 1rem;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #0f172a;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        .modern-input:focus {
            outline: none;
            border-color: #0f172a;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(15, 23, 42, 0.1);
        }

        .modern-btn {
            width: 100%;
            padding: 0.85rem;
            background: #0f172a;
            color: #ffffff;
            border-radius: 12px;
            border: none;
            font-weight: 600;
            font-size: 1rem;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.2);
            margin-top: 1rem;
        }

        .modern-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(15, 23, 42, 0.3);
        }

        .alert-modern {
            border-radius: 10px;
            border: none;
            background: #fef2f2;
            color: #b91c1c;
            padding: 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        /* Utility styles */
        .mb-4 { margin-bottom: 1.5rem; }
        .d-flex { display: flex; }
        .justify-content-between { justify-content: space-between; }
        .text-center { text-align: center; }
        .text-muted { color: #6c757d; }
        .mt-4 { margin-top: 1.5rem; }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-bg-shape1"></div>
        <div class="auth-bg-shape2"></div>
        
        <div class="auth-card">
            <div class="auth-header">
                <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #1e3a8a, #0f172a); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; box-shadow: 0 4px 15px rgba(15, 23, 42, 0.3);">
                    <i class="bi bi-shield-lock-fill" style="color: white; font-size: 1.5rem;"></i>
                </div>
                <h2>Admin Portal</h2>
                <p>Retail Management System</p>
            </div>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert-modern">
                    <i class="bi bi-exclamation-circle-fill"></i> <%= error %>
                </div>
            <% } %>
            
            <form method="POST" action="/admin/login">
                <div class="form-group">
                    <label for="username" class="modern-label">Admin Username</label>
                    <input type="text" class="modern-input" id="username" name="username" placeholder="Enter admin username" required autofocus>
                </div>
                
                <div class="form-group mb-4">
                    <div class="d-flex justify-content-between">
                        <label for="password" class="modern-label">Admin Password</label>
                    </div>
                    <input type="password" class="modern-input" id="password" name="password" placeholder="••••••••" required>
                </div>
                
                <button type="submit" class="modern-btn"><i class="bi bi-box-arrow-in-right" style="margin-right: 8px;"></i>Secure Login</button>
            </form>
            
            <div class="text-center mt-4 text-muted" style="font-size: 0.85rem; color: #94a3b8;">
                <i class="bi bi-info-circle me-1"></i> Default credentials: aa / aa
                <br>
                <a href="/" style="color: #0f172a; text-decoration: none; margin-top: 10px; display: inline-block;">Return to Homepage</a>
            </div>
        </div>
    </div>
</body>
</html>