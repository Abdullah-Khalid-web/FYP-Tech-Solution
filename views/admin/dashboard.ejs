    <div class="sa-wrapper">
        <%- include('partials/admin-sidebar') %>

        <div class="sa-main">
            <%- include('partials/admin-topbar') %>

            <!-- Content -->
            <div class="sa-content">
                <!-- Stat Cards -->
                <div class="sa-stats">
                    <div class="sa-stat">
                        <div class="sa-stat-top">
                            <div class="sa-stat-icon"><i class="fas fa-store"></i></div>
                            <div>
                                <div class="sa-stat-number"><%= stats.totalShops %></div>
                                <div class="sa-stat-label">Total Shops</div>
                            </div>
                        </div>
                        <div class="sa-stat-sub">
                            <span class="text-primary"><i class="fas fa-check-circle"></i> <%= stats.activeShops %> Active</span>
                            <span class="text-muted"><i class="fas fa-times-circle"></i> <%= stats.inactiveShops %> Inactive</span>
                        </div>
                    </div>

                    <div class="sa-stat">
                        <div class="sa-stat-top">
                            <div class="sa-stat-icon"><i class="fas fa-credit-card"></i></div>
                            <div>
                                <div class="sa-stat-number"><%= subscriptionStats.activeSubscriptions %></div>
                                <div class="sa-stat-label">Active Subscriptions</div>
                            </div>
                        </div>
                        <div class="sa-stat-sub">
                            <span class="text-primary"><i class="fas fa-clock"></i> <%= expiringSubscriptions.length %> Expiring Soon</span>
                        </div>
                    </div>

                    <div class="sa-stat">
                        <div class="sa-stat-top">
                            <div class="sa-stat-icon"><i class="fas fa-exclamation-circle"></i></div>
                            <div>
                                <div class="sa-stat-number"><%= subscriptionStats.expiredSubscriptions %></div>
                                <div class="sa-stat-label">Expired Subscriptions</div>
                            </div>
                        </div>
                        <div class="sa-stat-sub">
                            <span class="text-muted">Need attention</span>
                        </div>
                    </div>

                    <div class="sa-stat">
                        <div class="sa-stat-top">
                            <div class="sa-stat-icon"><i class="fas fa-ban"></i></div>
                            <div>
                                <div class="sa-stat-number"><%= stats.blockedShops %></div>
                                <div class="sa-stat-label">Blocked Shops</div>
                            </div>
                        </div>
                        <div class="sa-stat-sub">
                            <span class="text-muted">Require review</span>
                        </div>
                    </div>
                </div>

                <!-- Two Column Grid -->
                <div class="sa-grid">
                    <!-- Recent Shops -->
                    <div class="sa-card">
                        <div class="sa-card-header">
                            <h2><i class="fas fa-store"></i> Recent Shops</h2>
                            <a href="/admin/shops" class="sa-view-all">View All →</a>
                        </div>
                        <div class="sa-card-body">
                            <table class="sa-table">
                                <thead>
                                    <tr>
                                        <th>Shop Name</th>
                                        <th>Plan</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% recentShops.forEach(shop => { %>
                                    <tr>
                                        <td>
                                            <div class="shop-name"><%= shop.name %></div>
                                            <div class="shop-email"><%= shop.email %></div>
                                        </td>
                                        <td>
                                            <% if (shop.plan_name) { %>
                                                <span class="sa-badge-plan"><%= shop.plan_name %></span>
                                            <% } else { %>
                                                <span class="sa-badge-noplan">No Plan</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="sa-badge-status sa-badge-<%= shop.status %>"><%= shop.status %></span>
                                        </td>
                                        <td><%= new Date(shop.created_at).toLocaleDateString() %></td>
                                        <td>
                                            <a href="/admin/shops/<%= shop.id %>" class="sa-btn-view" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                                    <% if (recentShops.length === 0) { %>
                                    <tr>
                                        <td colspan="5">
                                            <div class="sa-empty"><p>No shops registered yet</p></div>
                                        </td>
                                    </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Expiring Subscriptions -->
                    <div class="sa-card">
                        <div class="sa-card-header">
                            <h2><i class="fas fa-clock"></i> Expiring Subscriptions</h2>
                            <span class="sa-badge sa-badge-warn"><%= expiringSubscriptions.length %> Shops</span>
                        </div>
                        <div class="sa-card-body">
                            <table class="sa-table">
                                <thead>
                                    <tr>
                                        <th>Shop</th>
                                        <th>Plan</th>
                                        <th>Expires</th>
                                        <th>Days Left</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% expiringSubscriptions.forEach(sub => { %>
                                    <tr>
                                        <td class="shop-name"><%= sub.shop_name %></td>
                                        <td><%= sub.plan_name %></td>
                                        <td><%= new Date(sub.expires_at).toLocaleDateString() %></td>
                                        <td>
                                            <span class="sa-badge-days <%= sub.days_remaining <= 3 ? 'urgent' : 'warn' %>">
                                                <%= sub.days_remaining %> days
                                            </span>
                                        </td>
                                        <td>
                                            <button class="sa-btn-extend" onclick="extendSubscription('<%= sub.shop_id %>', '<%= sub.shop_name %>')">
                                                <i class="fas fa-plus-circle"></i> Extend
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                    <% if (expiringSubscriptions.length === 0) { %>
                                    <tr>
                                        <td colspan="5">
                                            <div class="sa-empty">
                                                <i class="fas fa-check-circle"></i>
                                                <p>No expiring subscriptions</p>
                                            </div>
                                        </td>
                                    </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="sa-card" style="animation-delay: 0.3s;">
                    <div class="sa-card-header">
                        <h2><i class="fas fa-bolt"></i> Quick Actions</h2>
                    </div>
                    <div class="sa-actions">
                        <a href="/admin/shops?status=blocked" class="sa-action-btn">
                            <i class="fas fa-ban"></i> Blocked Shops
                        </a>
                        <a href="/admin/shops?status=inactive" class="sa-action-btn">
                            <i class="fas fa-pause"></i> Inactive Shops
                        </a>
                        <a href="/admin/feedback?status=new" class="sa-action-btn">
                            <i class="fas fa-envelope"></i> New Feedback
                        </a>
                        <a href="/admin/users" class="sa-action-btn">
                            <i class="fas fa-user-cog"></i> Manage Users
=======
