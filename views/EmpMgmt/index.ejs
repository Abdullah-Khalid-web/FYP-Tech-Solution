        async function manageSalary(empId) {
            try {
                const row = document.querySelector(`[data-emp-id="${empId}"]`).closest('.employee-card');
                if (!row) {
                    showNotification('Employee card not found', 'error');
                    return;
                }

                const empName = row.querySelector('.card-title')?.textContent || 'Unknown Employee';
                const salaryText = row.querySelector('.text-primary')?.textContent || '';
                const salaryMatch = salaryText.match(/(\d+\.?\d*)/);
                const baseSalary = salaryMatch ? parseFloat(salaryMatch[0]) : 0;

                // Fill modal fields
                document.getElementById('salaryUserId').value = empId;
                document.getElementById('salaryEmpName').value = empName;
                document.getElementById('salaryBaseAmount').value = baseSalary;
                document.getElementById('salaryBonus').value = 0;
                document.getElementById('salaryFine').value = 0;
                document.getElementById('salaryNotes').value = '';
                document.getElementById('salaryPaidOn').valueAsDate = new Date();

                // Load loans for deduction
                await loadEmployeeLoansForSalary(empId, baseSalary);
                calculateTotalPayable();

                // Show modal
