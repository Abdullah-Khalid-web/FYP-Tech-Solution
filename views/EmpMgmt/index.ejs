    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Update datetime every second
        function updateDateTime() {
            const now = new Date();
            const options = {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            };
            document.getElementById('datetime').textContent = now.toLocaleDateString('en-US', options);
        }

        setInterval(updateDateTime, 1000);
        updateDateTime(); // Initial call

        // Initialize modals
        let modals = {};

        function initializeModals() {
            const modalIds = [
                'addEmployeeModal',
                'salaryModal',
                'loanModal',
                'editEmployeeModal',
                'employeeDetailsModal',
                'quickLoanModal',
                'directLoanPaymentModal'
            ];

            modalIds.forEach(modalId => {
                const modalElement = document.getElementById(modalId);
                if (modalElement) {
                    modals[modalId] = new bootstrap.Modal(modalElement);
                }
            });
        }

        // Initialize when DOM is loaded
        document.addEventListener('DOMContentLoaded', function () {
            initializeModals();
            initializeEventListeners();
            setupEventDelegation();
        });

        function setupEventDelegation() {
            // Handle click events on dynamically loaded elements
            document.addEventListener('click', function (e) {
                // View Employee
                if (e.target.closest('.view-employee')) {
                    e.preventDefault();
                    const button = e.target.closest('.view-employee');
                    const empId = button.getAttribute('data-emp-id');
                    viewEmployeeDetails(empId);
                }

                // Edit Employee
                if (e.target.closest('.edit-employee')) {
                    e.preventDefault();
                    const button = e.target.closest('.edit-employee');
                    const empId = button.getAttribute('data-emp-id');
                    editEmployee(empId);
                }

                // Manage Salary
                if (e.target.closest('.manage-salary')) {
                    e.preventDefault();
                    const button = e.target.closest('.manage-salary');
                    const empId = button.getAttribute('data-emp-id');
                    manageSalary(empId);
                }

                // Manage Loan
                if (e.target.closest('.manage-loan')) {
                    e.preventDefault();
                    const button = e.target.closest('.manage-loan');
                    const empId = button.getAttribute('data-emp-id');
                    manageLoan(empId);
                }

                // Direct Loan Payment
                if (e.target.closest('.direct-loan-payment')) {
                    e.preventDefault();
                    const button = e.target.closest('.direct-loan-payment');
                    const empId = button.getAttribute('data-emp-id');
                    openDirectLoanPayment(empId);
                }

                // Quick Pay Salary
                if (e.target.closest('.quick-pay-btn')) {
                    e.preventDefault();
                    const button = e.target.closest('.quick-pay-btn');
                    const empId = button.getAttribute('data-emp-id');
                    const salary = button.getAttribute('data-salary');
                    quickPaySalary(empId, salary);
                }

                // Delete Employee (from dropdown)
                if (e.target.closest('.delete-employee')) {
                    e.preventDefault();
                    const button = e.target.closest('.delete-employee');
                    const empId = button.getAttribute('data-emp-id');
                    deleteEmployee(empId);
                }

                // Activate/Deactivate Employee
                if (e.target.closest('.activate-employee')) {
                    e.preventDefault();
                    const button = e.target.closest('.activate-employee');
                    const empId = button.getAttribute('data-emp-id');
                    toggleEmployeeStatus(empId, 'active');
                }

                if (e.target.closest('.deactivate-employee')) {
                    e.preventDefault();
                    const button = e.target.closest('.deactivate-employee');
                    const empId = button.getAttribute('data-emp-id');
                    toggleEmployeeStatus(empId, 'inactive');
                }
            });
        }

        function initializeEventListeners() {
            // Save buttons
            document.getElementById('saveEmployeeBtn')?.addEventListener('click', saveEmployee);
            document.getElementById('updateEmployeeBtn')?.addEventListener('click', updateEmployee);
            document.getElementById('saveQuickLoanBtn')?.addEventListener('click', saveQuickLoan);
            document.getElementById('saveSalaryBtn')?.addEventListener('click', saveSalary);
            document.getElementById('saveLoanBtn')?.addEventListener('click', saveLoan);
            document.getElementById('processDirectPaymentBtn')?.addEventListener('click', processDirectPayment);

            // Quick actions
            document.getElementById('payAllSalaries')?.addEventListener('click', payAllSalaries);
            document.getElementById('quickLoanBtn')?.addEventListener('click', function () {
                modals.quickLoanModal?.show();
            });

            // Filters
            document.getElementById('applyFilters')?.addEventListener('click', applyFilters);
            document.getElementById('resetFilters')?.addEventListener('click', resetFilters);

            // Loan modal functionality
            const loanType = document.getElementById('loanType');
            if (loanType) {
                loanType.addEventListener('change', function () {
                    const installmentSection = document.getElementById('installmentSection');
                    if (installmentSection) {
                        installmentSection.style.display = this.value === 'installment' ? 'block' : 'none';
                        calculateInstallment();
                    }
                });
            }

            const loanAmount = document.getElementById('loanAmount');
            const loanInstallments = document.getElementById('loanInstallments');
            if (loanAmount) loanAmount.addEventListener('input', calculateInstallment);
            if (loanInstallments) loanInstallments.addEventListener('input', calculateInstallment);

            // Salary calculation
            const salaryBonus = document.getElementById('salaryBonus');
            const salaryFine = document.getElementById('salaryFine');
            if (salaryBonus) salaryBonus.addEventListener('input', calculateTotalPayable);
            if (salaryFine) salaryFine.addEventListener('input', calculateTotalPayable);

            // Auto-fill features for better UX
            setupAutoFillFeatures();
        }

        function setupAutoFillFeatures() {
            // Auto-generate email from name
            const nameField = document.querySelector('input[name="name"]');
            const emailField = document.querySelector('input[name="email"]');

            if (nameField && emailField) {
                nameField.addEventListener('blur', function () {
                    if (!emailField.value && this.value) {
                        const name = this.value.toLowerCase().replace(/\s+/g, '.');
                        emailField.value = name + '@company.com';
                    }
                });
            }

            // Auto-suggest salary based on role
            const roleField = document.querySelector('select[name="role"]');
            const salaryField = document.querySelector('input[name="salary"]');

            if (roleField && salaryField) {
                roleField.addEventListener('change', function () {
                    if (!salaryField.value) {
                        const salaries = {
                            'owner': 100000,
                            'manager': 50000,
                            'cashier': 25000,
                            'sales': 20000,
                            'worker': 15000
                        };

                        const role = this.value.toLowerCase();
                        if (salaries[role]) {
                            salaryField.value = salaries[role];
                        }
                    }
                });
            }
        }

