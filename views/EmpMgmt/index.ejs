                console.log('Managing loan for employee:', { empId, empName });

                // Reset and fill modal fields
                const loanUserId = document.getElementById('loanUserId');
                const loanEmpName = document.getElementById('loanEmpName');

                if (loanUserId) loanUserId.value = empId;
                if (loanEmpName) loanEmpName.value = empName;

                // Reset form fields
                const loanAmount = document.getElementById('loanAmount');
                const loanReason = document.getElementById('loanReason');
                const loanType = document.getElementById('loanType');
