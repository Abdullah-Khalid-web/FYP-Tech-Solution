        async function loadEmployeeLoansForSalary(empId, baseSalary) {
            const loanList = document.getElementById('loanDeductionList');
            if (!loanList) return;

            loanList.innerHTML = '<div class="text-center text-muted py-3"><i class="fas fa-spinner fa-spin me-2"></i>Loading loans...</div>';

            try {
                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${empId}`);
                const data = await response.json();

                if (data.success && data.activeLoans && data.activeLoans.length > 0) {
                    let html = '';
                    data.activeLoans.forEach(loan => {
                        const suggestedDeduction = loan.installment_amount || Math.min(loan.total_balance, baseSalary * 0.5);

                        html += `
                        <div class="loan-item mb-3">
                            <div class="form-check">
                                <input class="form-check-input loan-checkbox" type="checkbox" 
                                    data-loan-id="${loan.id}" 
                                    id="loan-${loan.id}"
                                    ${loan.loan_type === 'installment' ? 'checked' : ''}
                                    ${loan.loan_type === 'installment' ? 'disabled' : ''}>
                                <label class="form-check-label w-100" for="loan-${loan.id}">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>${loan.description}</strong>
                                            <small class="text-muted d-block">${loan.loan_number} | Installment: ${loan.installment_amount ? loan.installment_amount.toLocaleString() : 'N/A'}</small>
                                        </div>
                                        <small class="text-danger">Balance: ${loan.total_balance.toLocaleString()}</small>
                                    </div>
                                </label>
                            </div>
                            <div class="mt-2">
                                <input type="number" class="form-control form-control-sm loan-deduction-amount" 
                                    value="${suggestedDeduction}" 
                                    min="0" max="${loan.total_balance}"
                                    data-loan-id="${loan.id}"
                                    step="0.01"
                                    ${loan.loan_type === 'installment' ? 'readonly' : ''}>
                                <small class="text-muted">Max: ${loan.total_balance.toLocaleString()}</small>
                            </div>
                        </div>`;
                    });
                    loanList.innerHTML = html;

                    // Add event listeners
                    document.querySelectorAll('.loan-checkbox, .loan-deduction-amount').forEach(element => {
                        element.addEventListener('change', calculateTotalPayable);
                    });
                } else {
                    loanList.innerHTML = '<div class="text-center text-muted py-3">No active loans found</div>';
                }
            } catch (error) {
                console.error('Error loading loans:', error);
                loanList.innerHTML = '<div class="text-center text-danger py-3">Error loading loans</div>';
            }
        }

        function calculateTotalPayable() {
            const baseSalary = parseFloat(document.getElementById('salaryBaseAmount')?.value) || 0;
            const bonus = parseFloat(document.getElementById('salaryBonus')?.value) || 0;
            const fine = parseFloat(document.getElementById('salaryFine')?.value) || 0;
            let totalDeductions = 0;

            document.querySelectorAll('.loan-checkbox:checked').forEach(checkbox => {
                const loanId = checkbox.getAttribute('data-loan-id');
                const amountInput = document.querySelector(`.loan-deduction-amount[data-loan-id="${loanId}"]`);
                if (amountInput) {
                    totalDeductions += parseFloat(amountInput.value) || 0;
                }
            });

            const totalPayable = baseSalary + bonus - fine - totalDeductions;
            const payableElement = document.getElementById('totalPayableAmount');
            if (payableElement) {
                payableElement.textContent = totalPayable > 0 ? totalPayable.toLocaleString() : '0';
            }
        }

        async function saveSalary() {
            const form = document.getElementById('salaryForm');
            if (!form) {
                showNotification('Salary form not found', 'error');
                return;
            }

            const formData = new FormData(form);
            const salaryData = {
                user_id: formData.get('user_id'),
                month: formData.get('month'),
                amount: parseFloat(document.getElementById('salaryBaseAmount').value),
                bonus: parseFloat(document.getElementById('salaryBonus').value) || 0,
                fine: parseFloat(document.getElementById('salaryFine').value) || 0,
                paid_on: formData.get('paid_on') || new Date().toISOString().split('T')[0],
                notes: formData.get('notes') || '',
                loan_deductions: []
            };

            // Collect loan deductions
            document.querySelectorAll('.loan-checkbox:checked').forEach(checkbox => {
                const loanId = checkbox.getAttribute('data-loan-id');
                const amountInput = document.querySelector(`.loan-deduction-amount[data-loan-id="${loanId}"]`);
                if (amountInput && parseFloat(amountInput.value) > 0) {
                    salaryData.loan_deductions.push({
                        loan_id: loanId,
                        amount: parseFloat(amountInput.value)
                    });
                }
            });

            try {
                showNotification('Processing salary payment...', 'info');
                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${salaryData.user_id}/salary`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(salaryData)
                });

                const data = await response.json();

                if (data.success) {
                    let message = 'Salary paid successfully!';
                    if (data.totalDeductions > 0) {
                        message += ` ${data.totalDeductions.toLocaleString()} deducted for loans.`;
                    }

                    modals.salaryModal?.hide();
                    showNotification(message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification('Error: ' + (data.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error saving salary:', error);
                showNotification('Error saving salary', 'error');
            }
        }

        async function manageLoan(empId) {
