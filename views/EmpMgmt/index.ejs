        async function saveLoan() {
            const userId = document.getElementById('loanUserId').value;
            const amount = document.getElementById('loanAmount').value;
            const reason = document.getElementById('loanReason').value;
            const loanType = document.getElementById('loanType').value;
            const installments = document.getElementById('loanInstallments')?.value || 1;

            // Validate required fields
            if (!userId) {
                showNotification('Employee not selected. Please try again.', 'error');
                return;
            }

            if (!amount || parseFloat(amount) <= 0) {
                showNotification('Please enter a valid loan amount', 'error');
                return;
            }

            if (!reason || reason.trim() === '') {
                showNotification('Please enter a reason for the loan', 'error');
                return;
            }

            const loanData = {
                amount: parseFloat(amount),
                description: reason.trim(),
                loan_type: loanType,
                installments: parseInt(installments)
            };

            console.log('Saving loan with data:', { userId, loanData });

            try {
                showNotification('Saving loan... Please wait', 'info');

                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${userId}/loan`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(loanData)
                });

                // Get response text first to see what's coming back
                const responseText = await response.text();
                console.log('Raw response:', responseText);

                let data;
                try {
                    data = JSON.parse(responseText);
                } catch (e) {
                    console.error('Failed to parse JSON:', responseText);
                    showNotification('Server error: Invalid response format', 'error');
                    return;
                }

                if (response.ok && data.success) {
                    modals.loanModal?.hide();
                    showNotification('Loan added successfully! Loan #: ' + (data.loanNumber || 'N/A'), 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    // Show detailed error message
                    const errorMsg = data.message || data.error || 'Unknown error occurred';
                    console.error('Loan save error:', errorMsg);
                    showNotification('Failed to add loan: ' + errorMsg, 'error');
                }
            } catch (error) {
                console.error('Error saving loan:', error);
                showNotification('Error saving loan: ' + error.message, 'error');
            }
        }

