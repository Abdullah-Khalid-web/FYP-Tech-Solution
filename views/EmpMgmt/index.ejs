                }

                // Get employee name from the card
                let empName = 'Unknown Employee';
                const empNameElement = row.querySelector('.card-title');
                if (empNameElement) {
                    empName = empNameElement.textContent.trim();
                }

                console.log('Found employee name:', empName);
                console.log('Employee ID:', empId);

                // Get modal elements
                const directPaymentUserId = document.getElementById('directPaymentUserId');
                const directPaymentEmpName = document.getElementById('directPaymentEmpName');

                if (!directPaymentUserId || !directPaymentEmpName) {
                    console.error('Modal elements not found');
                    showNotification('Error: Modal elements not found', 'error');
                    return;
                }

                // Set values
                directPaymentUserId.value = empId;
                directPaymentEmpName.value = empName;

                // Reset form fields
                const directPaymentAmount = document.getElementById('directPaymentAmount');
                const directPaymentNotes = document.getElementById('directPaymentNotes');
                const directPaymentMethod = document.getElementById('directPaymentMethod');
                const directPaymentDate = document.getElementById('directPaymentDate');

                if (directPaymentAmount) directPaymentAmount.value = '';
                if (directPaymentNotes) directPaymentNotes.value = '';
                if (directPaymentMethod) directPaymentMethod.value = 'cash';
                if (directPaymentDate) {
                    const today = new Date().toISOString().split('T')[0];
                    directPaymentDate.value = today;
                }

                // Reset total selected amount
                const totalSelectedAmount = document.getElementById('totalSelectedAmount');
                if (totalSelectedAmount) totalSelectedAmount.value = '0';

                // Load employee loans
                await loadEmployeeLoansForPayment(empId);

                // Show modal
                const modalElement = document.getElementById('directLoanPaymentModal');
                if (modalElement) {
                    let modalInstance = bootstrap.Modal.getInstance(modalElement);
                    if (!modalInstance) {
                        modalInstance = new bootstrap.Modal(modalElement);
                        modals.directLoanPaymentModal = modalInstance;
                    }
                    modalInstance.show();
                    console.log('Modal shown');
                } else {
                    showNotification('Could not open payment modal', 'error');
                }

            } catch (error) {
                console.error('Error opening direct payment modal:', error);
                showNotification('Error opening payment modal: ' + error.message, 'error');
            }
        }

        async function loadEmployeeLoansForPayment(empId) {
            const loanList = document.getElementById('loanPaymentList');
            if (!loanList) return;

            loanList.innerHTML = '<div class="text-center text-muted py-3"><i class="fas fa-spinner fa-spin me-2"></i>Loading loans...</div>';

            try {
                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${empId}`);
                const data = await response.json();

                if (data.success && data.activeLoans && data.activeLoans.length > 0) {
                    // This is the HTML for each loan item
                let html = '';
                    data.activeLoans.forEach(loan => {
                        html += `
                    <div class="loan-item mb-3 border-bottom pb-2">
                        <div class="form-check">
                            <input class="form-check-input loan-checkbox" type="checkbox" 
                                data-loan-id="${loan.id}" 
                                data-loan-balance="${loan.total_balance}"
                                id="loan-${loan.id}">
                            <label class="form-check-label w-100" for="loan-${loan.id}">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>${loan.loan_number}</strong>
                                        <small class="text-muted d-block">${loan.description || 'No description'}</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="text-danger fw-bold">Balance: ${parseFloat(loan.total_balance).toLocaleString()}</span>
                                        <small class="text-muted d-block">Installment: ${loan.installment_amount ? parseFloat(loan.installment_amount).toLocaleString() : 'N/A'}</small>
                                    </div>
                                </div>
                            </label>
                        </div>
                        <div class="mt-2 ms-4">
                            <label class="form-label small">Payment Amount for this Loan</label>
                            <input type="number" class="form-control form-control-sm loan-payment-amount" 
                                data-loan-id="${loan.id}"
                                data-max-amount="${loan.total_balance}"
                                placeholder="Leave empty for full balance"
                                min="0" max="${loan.total_balance}" step="0.01" disabled>
                            <small class="text-muted">Enter specific amount or leave empty to pay full balance</small>
                        </div>
                    </div>`;
                    });
                    loanList.innerHTML = html;

                    // Add event listeners for checkboxes
                    document.querySelectorAll('.loan-checkbox').forEach(checkbox => {
                        checkbox.addEventListener('change', function () {
                            const loanId = this.getAttribute('data-loan-id');
                            const amountInput = document.querySelector(`.loan-payment-amount[data-loan-id="${loanId}"]`);
                            if (amountInput) {
                                amountInput.disabled = !this.checked;
                                if (!this.checked) {
                                    amountInput.value = '';
                                }
                            }
                            calculateTotalSelectedAmount();
                        });
                    });

                    // Add event listeners for amount inputs
                    document.querySelectorAll('.loan-payment-amount').forEach(input => {
                        input.addEventListener('input', function () {
                            const maxAmount = parseFloat(this.getAttribute('data-max-amount'));
                            let value = parseFloat(this.value);
                            if (isNaN(value)) value = 0;
                            if (value > maxAmount) {
                                this.value = maxAmount;
                                showNotification(`Amount cannot exceed balance of ${maxAmount.toLocaleString()}`, 'warning');
                            }
                            calculateTotalSelectedAmount();
                        });
                    });
                } else {
                    loanList.innerHTML = '<div class="text-center text-muted py-3">No active loans found for this employee</div>';
                }
            } catch (error) {
                console.error('Error loading loans:', error);
                loanList.innerHTML = '<div class="text-center text-danger py-3">Error loading loans</div>';
                showNotification('Error loading loan data', 'error');
            }
        }

        function calculateTotalSelectedAmount() {
            let totalAmount = 0;
            document.querySelectorAll('.loan-checkbox:checked').forEach(checkbox => {
                const loanId = checkbox.getAttribute('data-loan-id');
                const amountInput = document.querySelector(`.loan-payment-amount[data-loan-id="${loanId}"]`);
                let amount = parseFloat(amountInput?.value);
                if (isNaN(amount) || amount === 0) {
                    // If no amount specified, use full balance
                    amount = parseFloat(checkbox.getAttribute('data-loan-balance'));
                }
                if (!isNaN(amount) && amount > 0) {
                    totalAmount += amount;
                }
            });
            document.getElementById('totalSelectedAmount').value = totalAmount.toLocaleString();
        }
async function processDirectPayment() {
    const empId = document.getElementById('directPaymentUserId').value;
    let totalPaymentAmount = parseFloat(document.getElementById('directPaymentAmount').value);
    let description = document.getElementById('directPaymentNotes').value;
    const paymentMethod = document.getElementById('directPaymentMethod').value;
    const paymentDate = document.getElementById('directPaymentDate').value;

    if (!empId) {
        showNotification('Employee not selected', 'error');
        return;
    }

    if (!totalPaymentAmount || totalPaymentAmount <= 0) {
        showNotification('Please enter a valid payment amount', 'error');
        return;
    }

    // Collect selected loans with their requested payment amounts
    const selectedLoans = [];
    let totalRequestedAmount = 0;

    document.querySelectorAll('.loan-checkbox:checked').forEach(checkbox => {
        const loanId = checkbox.getAttribute('data-loan-id');
        const loanBalance = parseFloat(checkbox.getAttribute('data-loan-balance'));
        const amountInput = document.querySelector(`.loan-payment-amount[data-loan-id="${loanId}"]`);
        let requestedAmount = parseFloat(amountInput?.value);
        
        // If no specific amount entered, use the full balance
        if (isNaN(requestedAmount) || requestedAmount === 0) {
            requestedAmount = loanBalance;
        }
        
        // Cap at loan balance
        requestedAmount = Math.min(requestedAmount, loanBalance);
        
        if (requestedAmount > 0) {
            selectedLoans.push({
                loan_id: loanId,
                amount: requestedAmount
            });
            totalRequestedAmount += requestedAmount;
        }
    });

    if (selectedLoans.length === 0) {
        showNotification('Please select at least one loan to pay', 'error');
        return;
    }

    // Validate that payment amount matches total requested amount
    // Allow small rounding errors (within 0.01)
    if (Math.abs(totalRequestedAmount - totalPaymentAmount) > 0.01) {
        showNotification(`Total selected amount (${totalRequestedAmount.toLocaleString()}) must equal payment amount (${totalPaymentAmount.toLocaleString()}). Please adjust the payment amount or the per-loan amounts.`, 'error');
        return;
    }

    // Prepare description with default if empty
    if (!description || description.trim() === '') {
        description = `Direct loan payment via ${paymentMethod}`;
    }

    const paymentData = {
        amount: totalPaymentAmount,
        loan_payments: selectedLoans,
        description: `${description} | Method: ${paymentMethod} | Date: ${paymentDate}`,
        payment_method: paymentMethod
    };

    console.log('Sending payment data (amounts):', paymentData.loan_payments.map(l => ({ loan_id: l.loan_id, amount: l.amount })));

    try {
        showNotification('Processing payment...', 'info');
        const response = await fetch(`/EmpMgmt/api/EmpMgmt/${empId}/loan/payment`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(paymentData)
        });

        const responseText = await response.text();
        console.log('Raw response:', responseText);

        let data;
        try {
            data = JSON.parse(responseText);
        } catch (e) {
            console.error('Failed to parse JSON:', responseText);
            showNotification('Server error: Invalid response format', 'error');
            return;
        }

        if (response.ok && data.success) {
            modals.directLoanPaymentModal?.hide();
            showNotification('Payment processed successfully! Amount paid: ' + totalPaymentAmount.toLocaleString(), 'success');
            setTimeout(() => location.reload(), 1500);
        } else {
            const errorMsg = data.message || data.error || 'Payment failed';
            console.error('Payment error:', errorMsg);
            showNotification('Error: ' + errorMsg, 'error');
        }
    } catch (error) {
        console.error('Error processing payment:', error);
        showNotification('Error processing payment: ' + error.message, 'error');
    }
}
function calculateInstallment() {
            const loanAmount = parseFloat(document.getElementById('loanAmount')?.value) || 0;
            const installments = parseInt(document.getElementById('loanInstallments')?.value) || 3;

            if (loanAmount > 0 && installments > 0) {
                const installmentAmount = Math.ceil(loanAmount / installments);
                const installmentInput = document.getElementById('loanInstallmentAmount');
                if (installmentInput) {
                    installmentInput.value = installmentAmount;
                }
            }
        }

        // Quick pay salary function
        async function quickPaySalary(empId, salary) {
            const row = document.querySelector(`[data-emp-id="${empId}"]`).closest('.employee-card');
            const empName = row.querySelector('.card-title').textContent;

            if (!confirm(`Pay ${parseFloat(salary).toLocaleString()} to ${empName}?`)) return;

            try {
                showNotification('Processing salary payment...', 'info');
                const salaryData = {
                    month: new Date().toISOString().slice(0, 7),
                    amount: parseFloat(salary),
                    bonus: 0,
                    fine: 0,
                    paid_on: new Date().toISOString().split('T')[0],
                    loan_deductions: []
                };

                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${empId}/salary`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(salaryData)
                });

                const data = await response.json();

                if (data.success) {
                    let message = `Salary paid successfully to ${empName}!`;
                    if (data.totalDeductions > 0) {
                        message += ` ${data.totalDeductions.toLocaleString()} deducted for loans.`;
                    }
                    showNotification(message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification('Error: ' + (data.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error paying salary:', error);
                showNotification('Error processing payment', 'error');
            }
        }

        async function deleteEmployee(empId) {
            const row = document.querySelector(`[data-emp-id="${empId}"]`).closest('.employee-card');
            const empName = row.querySelector('.card-title').textContent;

            if (!confirm(`Are you sure you want to delete ${empName}? This action cannot be undone.`)) return;

            try {
                showNotification('Deleting employee...', 'info');
                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${empId}`, {
                    method: 'DELETE'
                });

                const data = await response.json();

                if (data.success) {
                    showNotification('Employee deleted successfully!', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification('Error: ' + (data.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error deleting employee:', error);
                showNotification('Error deleting employee', 'error');
            }
        }

        async function payAllSalaries() {
            if (!confirm('Pay salaries to all active employees for this month?')) return;

            try {
                showNotification('Processing bulk payment...', 'info');
                // Get all active employees
                const employees = document.querySelectorAll('.employee-card');
                let processed = 0;

                for (const empCard of employees) {
                    const empId = empCard.querySelector('.view-employee')?.getAttribute('data-emp-id');
                    const salary = empCard.querySelector('.quick-pay-btn')?.getAttribute('data-salary');

                    if (empId && salary) {
                        const salaryData = {
                            month: new Date().toISOString().slice(0, 7),
                            amount: parseFloat(salary),
                            bonus: 0,
                            fine: 0,
                            paid_on: new Date().toISOString().split('T')[0],
                            loan_deductions: []
                        };

                        const response = await fetch(`/EmpMgmt/api/EmpMgmt/${empId}/salary`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(salaryData)
                        });

                        const data = await response.json();
                        if (data.success) {
                            processed++;
                        }
                    }
                }

                showNotification(`Bulk payment completed! ${processed} salaries paid.`, 'success');
                setTimeout(() => location.reload(), 1500);
            } catch (error) {
                console.error('Error processing bulk payment:', error);
                showNotification('Error processing bulk payment', 'error');
            }
        }

        async function saveEmployee() {
            const form = document.getElementById('addEmployeeForm');
            const formData = new FormData(form);

            if (formData.get('password') !== formData.get('confirmPassword')) {
                showNotification('Passwords do not match!', 'error');
                return;
            }

            try {
                showNotification('Saving employee...', 'info');
                const employeeData = {
                    name: formData.get('name'),
                    email: formData.get('email'),
                    phone: formData.get('phone'),
                    cnic: formData.get('cnic'),
                    role: formData.get('role'),
                    salary: formData.get('salary') ? parseFloat(formData.get('salary')) : null,
                    password: formData.get('password'),
                    notes: formData.get('notes')
                };

                const response = await fetch('/EmpMgmt/api/EmpMgmt', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(employeeData)
                });

                const data = await response.json();

                if (data.success) {
                    modals.addEmployeeModal?.hide();
                    form.reset();
                    showNotification('Employee added successfully!', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification('Error: ' + (data.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error saving employee:', error);
                showNotification('Error saving employee', 'error');
            }
        }

        async function saveQuickLoan() {
            const employeeSelect = document.getElementById('quickLoanEmployee');
            const amountInput = document.getElementById('quickLoanAmount');
            const reasonInput = document.getElementById('quickLoanReason');

            if (!employeeSelect.value || !amountInput.value || !reasonInput.value) {
                showNotification('Please fill all required fields', 'error');
                return;
            }

            const loanData = {
                amount: parseFloat(amountInput.value),
                description: reasonInput.value
            };

            try {
                showNotification('Saving loan...', 'info');
                const response = await fetch(`/EmpMgmt/api/EmpMgmt/${employeeSelect.value}/loan`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(loanData)
                });

                const data = await response.json();

                if (data.success) {
                    modals.quickLoanModal?.hide();
                    showNotification('Quick loan added successfully!', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification('Error: ' + (data.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error saving quick loan:', error);
                showNotification('Error saving quick loan', 'error');
            }
        }

        function showNotification(message, type = 'info') {
            // Remove existing notifications
            const existingNotifications = document.querySelectorAll('.custom-notification');
            existingNotifications.forEach(n => n.remove());

            // Create notification element
            const notification = document.createElement('div');
            let alertClass = '';
            let icon = '';

            switch (type) {
                case 'success':
                    alertClass = 'alert-success';
                    icon = 'fa-check-circle';
                    break;
                case 'error':
                    alertClass = 'alert-danger';
                    icon = 'fa-exclamation-circle';
                    break;
                case 'warning':
                    alertClass = 'alert-warning';
                    icon = 'fa-exclamation-triangle';
                    break;
                default:
                    alertClass = 'alert-info';
                    icon = 'fa-info-circle';
            }

            notification.className = `alert ${alertClass} alert-dismissible fade show custom-notification`;
            notification.innerHTML = `
        <div class="d-flex align-items-center">
            <i class="fas ${icon} me-2" style="font-size: 1.2rem;"></i>
            <span style="flex: 1;">${message}</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    `;

            // Add to page
            document.body.appendChild(notification);

            // Auto remove after 5 seconds
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.parentNode.removeChild(notification);
                }
            }, 5000);
        }
        function applyFilters() {
            const roleFilter = document.getElementById('roleFilter').value;
            const statusFilter = document.getElementById('statusFilter').value;
            const searchFilter = document.getElementById('searchFilter').value;
            const salaryFilter = document.getElementById('salaryFilter').value;

            const params = new URLSearchParams();
            params.append('page', '1');

            if (roleFilter && roleFilter !== 'all') params.append('role', roleFilter);
            if (statusFilter && statusFilter !== 'all') params.append('status', statusFilter);
            if (searchFilter) params.append('search', searchFilter);
            if (salaryFilter && salaryFilter !== 'all') params.append('salaryRange', salaryFilter);

            window.location.href = `/EmpMgmt?${params.toString()}`;
        }

        function resetFilters() {
            window.location.href = '/EmpMgmt?page=1';
        }
    </script>
