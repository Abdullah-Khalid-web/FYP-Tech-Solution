<style>
    .modern-footer {
        background: #0f172a;
        /* Custom slate requested by user */
        color: #ffffff;
        padding: 60px 0 30px;
        margin-top: 80px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        position: relative;
        border-top: 5px solid #ffffff;
    }

    .modern-footer a {
        color: #ffffff;
        text-decoration: none;
        transition: opacity 0.3s ease;
        font-weight: 500;
    }

    .modern-footer a:hover {
        color: #ffffff;
        opacity: 0.8;
    }

    .footer-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.3);
        margin: 30px 0;
    }
</style>

<footer class="modern-footer">
    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-3 text-center text-lg-start">
                <h4 style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 1.5rem; color: #ffffff;">
                    <%= typeof shop !=='undefined' && shop ? shop.name : 'Manage Hub' %>
                </h4>
                <p class="mb-0 mt-3" style="color: #ffffff; font-size: 0.95rem;">
                    &copy; <%= new Date().getFullYear() %> All Rights Reserved.
                </p>
                <% if (typeof shop !=='undefined' && shop && shop.address) { %>
                    <p class="mt-2 small" style="margin-bottom: 0; color: #ffffff;">
                        <%= shop.address %>
                    </p>
                    <% } %>
            </div>

            <div class="col-lg-3 text-center border-lg-start border-lg-end"
                style="border-color: rgba(255,255,255,0.3) !important;">
                <h6 class="text-uppercase mb-3" style="letter-spacing: 1px; color: #ffffff; font-weight: 800;">Contact
                    Us</h6>
                <% if (typeof shop !=='undefined' && shop && shop.phone) { %>
                    <p class="mb-1"><a href="tel:<%= shop.phone %>">
                            <%= shop.phone %>
                        </a></p>
                    <% } else { %>
                        <p class="mb-1"><a href="tel:+923331223334444">+92 333 1223334444</a></p>
                        <% } %>

                            <% if (typeof shop !=='undefined' && shop && shop.email) { %>
                                <p class="mb-0"><a href="mailto:<%= shop.email %>">
                                        <%= shop.email %>
                                    </a></p>
                                <% } else { %>
                                    <p class="mb-0"><a
                                            href="mailto:NextGenTechSolution@gmail.com">NextGenTechSolution@gmail.com</a>
                                    </p>
                                    <% } %>
            </div>

            <div class="col-lg-3 text-center text-lg-start ps-lg-4">
                <h6 class="text-uppercase mb-3" style="letter-spacing: 1px; color: #ffffff; font-weight: 800;">Quick
                    Links</h6>
                <ul class="list-unstyled mb-0" style="line-height: 1.8;">
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/contact">Contact</a></li>
                    <li><a href="/privacy">Privacy Policy</a></li>
                </ul>
            </div>

            <div class="col-lg-3 text-center text-lg-end">
                <h6 class="text-uppercase mb-3" style="letter-spacing: 1px; color: #ffffff; font-weight: 800;">Powered
                    By</h6>
                <p class="mb-1" style="color: #ffffff;"><strong>NextGen TechSolution</strong></p>
                <div class="mt-3">
                    <a href="/admin" class="btn btn-sm"
                        style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.5); color: #ffffff; border-radius: 50px; padding: 6px 15px; font-weight: 600;">Admin
                        Panel</a>
                </div>
            </div>
        </div>

        <div class="footer-divider"></div>

        <div class="text-center">
            <small style="color: #ffffff; font-weight: 500;">Manage Hub Ecosystem — Crafted for Retail
                Intelligence</small>
        </div>
    </div>
</footer>