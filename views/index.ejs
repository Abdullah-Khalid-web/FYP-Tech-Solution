}

.feature-desc {
    color: var(--text-muted);
    line-height: 1.6;
}

/* AI Workflow Section */
.workflow-step {
    text-align: center;
    padding: 2rem;
    position: relative;
    animation: slideUpFade 1s ease-out backwards;
}
.workflow-step:before {
    content: '';
    position: absolute;
    top: 50px;
    right: -50%;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--primary) 0%, transparent 100%);
    opacity: 0.3;
    z-index: -1;
}
@media(max-width: 991px) {
    .workflow-step:before { display: none; }
}
.workflow-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    color: var(--primary);
    margin: 0 auto 20px;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.2);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.workflow-step:hover .workflow-icon {
    transform: scale(1.1) rotate(10deg);
    background: var(--primary);
    color: #ffffff;
}
.workflow-step:nth-child(1) { animation-delay: 0.1s; }
.workflow-step:nth-child(2) { animation-delay: 0.3s; }
.workflow-step:nth-child(3) { animation-delay: 0.5s; }

/* Testimonials Marquee */
.marquee-container {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    padding: 40px 0;
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
}
.marquee-content {
    display: inline-block;
    animation: scrollMarquee 30s linear infinite;
}
.testimonial-card {
    display: inline-block;
    width: 350px;
    white-space: normal;
    margin: 0 15px;
    vertical-align: top;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 10px 30px -10px var(--shadow-color);
}
@keyframes scrollMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
@keyframes slideUpFade {
    0% { opacity: 0; transform: translateY(40px); }
    100% { opacity: 1; transform: translateY(0); }
}
@keyframes ping {
    75%, 100% { transform: scale(2.5); opacity: 0; }
}
@keyframes bounceSoft {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
}
@keyframes ripple {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.6); opacity: 0; }
}
@keyframes pulseGlow {
    0% { transform: scale(1); box-shadow: 0 0 20px rgba(139, 92, 246, 0.4); }
    100% { transform: scale(1.05); box-shadow: 0 0 45px rgba(139, 92, 246, 0.8); }
}
@keyframes dataFlow {
    0% { left: -40%; }
    100% { left: 140%; }
}

.workflow-step:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    border-color: rgba(99, 102, 241, 0.3);
}
.workflow-step:hover .workflow-icon {
    transform: scale(1.1) rotate(5deg);
}

/* Stats */
.stat-item {
    text-align: center;
