@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Plus+Jakarta+Sans:wght@400;500;700&display=swap');
@import url('https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css');

:root {
    /* Premium SaaS Blue Theme (Light Mode) */
    --bg-main: #ffffff;
    --bg-card: rgba(255, 255, 255, 0.8);
    --primary: #0f172a;
    --primary-glow: rgba(15, 23, 42, 0.2);
    --secondary: #3b82f6;
    --accent: #0ea5e9;
    --text-main: #0f172a;
    --text-muted: #64748b;
    --text-light: #f8fafc;
    --glass-border: rgba(0, 0, 0, 0.05);
    --feature-bg: #f8fafc;
    --shadow-color: rgba(0, 0, 0, 0.08);
}

[data-theme="dark"] {
    /* Dark Mode Overrides */
    --bg-main: #0f172a;
    --bg-card: rgba(30, 41, 59, 0.7);
    --text-main: #f8fafc;
    --text-muted: #94a3b8;
    --glass-border: rgba(255, 255, 255, 0.08);
    --feature-bg: #0f172a;
    --shadow-color: rgba(0, 0, 0, 0.4);
}

body {
    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: 'Plus Jakarta Sans', sans-serif;
    overflow-x: hidden;
    transition: background-color 0.3s ease, color 0.3s ease;
}

h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-main);
}

/* Background Gradients */
.bg-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
    top: -150px;
    left: -150px;
    z-index: 0;
    filter: blur(80px);
    animation: floatGlow 15s ease-in-out infinite alternate;
}

.bg-glow-right {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(38, 132, 255, 0.15) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    z-index: 0;
    filter: blur(80px);
    animation: floatGlow 20s ease-in-out infinite alternate-reverse;
}

@keyframes floatGlow {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(50px, 50px) scale(1.1); }
}

/* Glassmorphism Utilities */
.glass-panel {
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    box-shadow: 0 10px 30px -10px var(--shadow-color);
    position: relative;
    z-index: 10;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                box-shadow 0.4s ease, border-color 0.4s ease, background 0.3s ease;
}

.glass-panel:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px rgba(15, 23, 42, 0.15);
    border-color: rgba(15, 23, 42, 0.2);
}

/* Hero Section */
.hero-wrapper {
    position: relative;
    padding: 120px 0 80px;
    min-height: 90vh;
    display: flex;
    align-items: center;
}

.hero-title {
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1.1;
    margin-bottom: 24px;
}

.hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 40px;
    max-width: 600px;
}

.text-gradient {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* Buttons */
.btn-glow {
    position: relative;
    background: linear-gradient(135deg, var(--secondary), var(--primary));
    color: white !important;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    padding: 14px 36px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    overflow: hidden;
    z-index: 1;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    box-shadow: 0 4px 15px var(--primary-glow);
}

.btn-glow::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
}

.btn-glow:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.6), 0 0 40px rgba(14, 165, 233, 0.4), 0 10px 25px -5px var(--primary-glow);
}

.btn-glow:hover::before {
    opacity: 1;
}

.btn-glass {
    background: rgba(15, 23, 42, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(15, 23, 42, 0.15);
    color: var(--primary) !important;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    padding: 14px 36px;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
}

.btn-glass:hover {
    background: rgba(15, 23, 42, 0.1);
    border-color: rgba(15, 23, 42, 0.3);
}

/* Floating Dashboard Mockup CSS */
.dashboard-mockup-wrapper {
    position: relative;
    width: 100%;
    height: 450px;
    perspective: 1000px;
}

.dash-main-card {
    position: absolute;
    width: 80%;
    height: 300px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotateY(-15deg) rotateX(10deg);
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    backdrop-filter: blur(16px);
    box-shadow: -20px 20px 40px var(--shadow-color);
    animation: float1 6s ease-in-out infinite alternate;
    padding: 20px;
    z-index: 2;
}

.dash-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
}
.dash-skeleton-title {
    width: 120px;
    height: 15px;
    background: var(--text-muted);
    opacity: 0.3;
    border-radius: 10px;
}
.dash-skeleton-btn {
    width: 80px;
    height: 15px;
    background: var(--primary);
    opacity: 0.5;
    border-radius: 10px;
}

.dash-chart {
    height: 150px;
    border-bottom: 2px dashed rgba(15,23,42,0.3);
    position: relative;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding-bottom: 10px;
}
.dash-bar {
    flex: 1;
    background: linear-gradient(to top, rgba(15,23,42,0.8), rgba(14,165,233,0.8));
    border-radius: 4px 4px 0 0;
}

.dash-floating-card-1 {
    position: absolute;
    width: 200px;
    height: auto;
    min-height: 110px;
    top: 40px;
    right: -30px;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    backdrop-filter: blur(12px);
    box-shadow: -10px 15px 30px var(--shadow-color);
    animation: float2 5s ease-in-out infinite alternate;
    padding: 15px;
    z-index: 3;
}

.dash-floating-card-2 {
    position: absolute;
    width: 210px;
    height: auto;
    min-height: 100px;
    bottom: 10px;
    left: -40px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 16px;
    box-shadow: 0 15px 35px var(--primary-glow);
    animation: float3 7s ease-in-out infinite alternate;
    padding: 15px;
    color: white;
    z-index: 1;
}

@keyframes float1 {
    0% { transform: translate(-50%, -50%) rotateY(-15deg) rotateX(10deg) translateY(0); }
    100% { transform: translate(-50%, -50%) rotateY(-15deg) rotateX(10deg) translateY(-20px); }
}
@keyframes float2 {
    0% { transform: translateY(0) translateZ(50px); }
    100% { transform: translateY(-15px) translateZ(50px); }
}
@keyframes float3 {
    0% { transform: translateY(0) translateZ(-30px); }
    100% { transform: translateY(20px) translateZ(-30px); }
}

/* Animated Section 3: Radar Pulse */
.radar-container {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    border: 2px solid rgba(15,23,42,0.1);
    position: relative;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle, rgba(15,23,42,0.05) 0%, transparent 70%);
}
.radar-sweep {
    position: absolute;
    width: 150px;
    height: 150px;
    top: 0;
    left: 150px;
    background: conic-gradient(from 0deg, transparent 70%, rgba(15,23,42,0.4) 100%);
    transform-origin: bottom left;
    animation: radarSweep 4s linear infinite;
    border-radius: 0 100% 0 0;
}
.radar-pulse {
    position: absolute;
    width: 15px;
    height: 15px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 15px var(--primary);
    animation: radarBlink 2s infinite;
    z-index: 5;
}
.rp-1 { top: 60px; left: 80px; animation-delay: 0.5s; }
.rp-2 { top: 120px; right: 60px; animation-delay: 1.2s; }
.rp-3 { bottom: 80px; left: 120px; animation-delay: 2.5s; }

@keyframes radarSweep {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
@keyframes radarBlink {
    0%, 100% { opacity: 0.1; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.5); box-shadow: 0 0 25px var(--primary); }
}

/* Animated Section 4: Integration Engine */
.integration-hub-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin: 40px auto;
}
@media (max-width: 768px) {
    .integration-hub-wrapper { flex-direction: column; gap: 40px; }
    .integration-wire { width: 4px !important; height: 50px !important; flex: none !important; }
}
.integration-node {
    width: 90px;
    height: 90px;
    background: var(--bg-card);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(15,23,42,0.2);
    position: relative;
    animation: floatNode 4s ease-in-out infinite alternate;
    box-shadow: 0 10px 20px var(--shadow-color);
}
.node-1 { animation-delay: 0s; }
.node-2 { animation-delay: 1s; }
.node-3 { animation-delay: 2s; }
.integration-center {
    width: 140px;
    height: 140px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 2.5rem;
    box-shadow: 0 0 40px var(--primary-glow);
    z-index: 2;
    animation: pulseCore 3s infinite;
}
.integration-wire {
    flex: 1;
    height: 4px;
    background: rgba(15,23,42,0.1);
    position: relative;
    overflow: hidden;
    border-radius: 4px;
}
.integration-wire::after {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, var(--primary), transparent);
    animation: flowWire 2.5s linear infinite;
}

@keyframes floatNode {
    from { transform: translateY(-10px); }
    to { transform: translateY(10px); }
}
@keyframes pulseCore {
    0%, 100% { transform: scale(1); box-shadow: 0 0 30px var(--primary-glow); }
    50% { transform: scale(1.05); box-shadow: 0 0 60px rgba(15,23,42,0.6); }
}
@keyframes flowWire {
    0% { left: -100%; top: -100%; }
    100% { left: 100%; top: 100%; }
}

/* Features Grid */
.features-section {
    padding: 100px 0;
    position: relative;
    z-index: 5;
    background: var(--feature-bg);
    transition: background 0.3s ease;
}

.feature-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--bg-card);
    border: 1.5px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--text-main);
    opacity: 0.8;
    margin-bottom: 24px;
    transition: all 0.3s ease;
}

.glass-panel:hover .feature-icon-wrapper {
    background: var(--primary);
    color: #ffffff;
    opacity: 1;
    transform: translateY(-5px);
    border-color: var(--primary);
    box-shadow: 0 5px 15px var(--primary-glow);
}

.feature-title {
    font-size: 1.5rem;
