<style>
.pricing-page { padding: 120px 0 70px; min-height: 80vh; background: var(--feature-bg, #f8fafc); }
.pricing-card { height: 100%; background: var(--bg-card, #fff); border: 1px solid var(--glass-border, #e2e8f0); border-radius: 8px; padding: 28px; box-shadow: 0 10px 28px -18px rgba(15,23,42,.3); display: flex; flex-direction: column; }
.pricing-card.popular { border-color: #3b82f6; box-shadow: 0 18px 40px -24px rgba(59,130,246,.8); }
.plan-price { font-size: 2.25rem; font-weight: 800; color: var(--text-main, #0f172a); }
.plan-muted { color: var(--text-muted, #64748b); }
.plan-features { list-style: none; padding: 0; margin: 22px 0; display: grid; gap: 10px; }
.plan-features li { color: var(--text-main, #0f172a); }
.plan-action { margin-top: auto; }
html[data-theme="dark"] .pricing-page { background: #0f172a; }
html[data-theme="dark"] .pricing-card { background: #1e293b; border-color: #334155; }
</style>

<section class="pricing-page">
  <div class="container">
    <div class="text-center mb-5">
      <h1 style="font-weight:800;color:var(--text-main,#0f172a);">Subscription Plans</h1>
      <p class="plan-muted">Choose a plan and subscribe from your portfolio settings after registration.</p>
    </div>

    <% const defaultPlans = [
      { name: 'Starter', description: 'Perfect for small shops', monthly_price: 0, features: ['Core billing', 'Products and stock', 'Basic reports'], plan_id: 'starter' },
      { name: 'Professional', description: 'For growing businesses', monthly_price: 4900, features: ['Advanced analytics', 'Employee management', 'AI assistant'], plan_id: 'professional' },
      { name: 'Enterprise', description: 'For larger teams', monthly_price: 9900, features: ['Unlimited workflows', 'Priority support', 'Full AI insights'], plan_id: 'enterprise' }
    ]; %>
    <% const plans = (pricingPlans && pricingPlans.length) ? pricingPlans : defaultPlans; %>

    <div class="row g-4">
      <% plans.forEach((plan, index) => {
        let features = [];
        try {
          features = Array.isArray(plan.features) ? plan.features : JSON.parse(plan.features || '[]');
        } catch (e) {
          features = String(plan.features || '').split(',').map(f => f.trim()).filter(Boolean);
        }
        if (!features.length) features = ['Business dashboard', 'Secure user access', 'Support included'];
        const popular = index === 1;
      %>
      <div class="col-md-4">
        <div class="pricing-card <%= popular ? 'popular' : '' %>">
          <% if (popular) { %><span class="badge bg-primary align-self-start mb-3">Most Popular</span><% } %>
          <h3 style="font-weight:800;color:var(--text-main,#0f172a);"><%= plan.name %></h3>
          <p class="plan-muted"><%= plan.description || 'Full access for your business operations' %></p>
          <div class="my-3">
            <span class="plan-price"><%= Number(plan.monthly_price || 0).toLocaleString('en-PK') %></span>
            <span class="plan-muted"> PKR / month</span>
          </div>
          <ul class="plan-features">
            <% features.forEach(feature => { %>
              <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
            <% }); %>
          </ul>
          <div class="plan-action">
            <% if (user) { %>
              <a class="btn btn-primary w-100" href="/shop_setting#plans">Subscribe</a>
            <% } else { %>
              <a class="btn btn-primary w-100" href="/register?plan=<%= encodeURIComponent(plan.name) %>">Get Started</a>
            <% } %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>
