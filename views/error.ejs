<%- include('partials/header', { title: 'Error', shop: shop }) %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <%= title || 'Error' %>
                    </h4>
                </div>
                <div class="card-body text-center py-5">
                    <i class="fas fa-exclamation-circle text-danger" style="font-size: 5rem;"></i>
                    
                    <h3 class="mt-4">Something Went Wrong</h3>
                    
                    <p class="text-muted mb-4">
                        <%= message || 'An unexpected error occurred.' %>
                    </p>
                    
                    <% if (error && process.env.NODE_ENV === 'development') { %>
                        <div class="alert alert-secondary text-start">
                            <pre class="mb-0"><%= error.stack %></pre>
                        </div>
                    <% } %>
                    
                    <div class="mt-4">
                        <a href="/dashboard" class="btn btn-primary me-2">
                            <i class="fas fa-home me-2"></i>
                            Go to Dashboard
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>
                            Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
