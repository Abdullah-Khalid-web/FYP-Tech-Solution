<style>
  body {
    background-color: #f8fafc;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .auth-wrapper {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7rem 1rem 2rem;
  }

  .auth-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    max-width: 460px;
    width: 100%;
    padding: 2.5rem;
    box-shadow: 0 20px 40px -20px rgba(15, 23, 42, .25);
  }

  .auth-card h2 {
    color: #0f172a;
    font-weight: 800;
    margin-bottom: .5rem;
  }

  .auth-card p {
    color: #64748b;
  }

  .modern-input {
    width: 100%;
    padding: .85rem 1rem;
    border-radius: 12px;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
    transition: all 0.3s ease;
  }

  .modern-input:focus {
    outline: none;
    border-color: #0f172a;
    box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.1);
  }

  .modern-btn {
    width: 100%;
    padding: .85rem;
    border: 0;
    border-radius: 12px;
    background: #0f172a;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .modern-btn:hover {
    background: #1e293b;
  }

  .alert-modern {
    border-radius: 10px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .alert-error {
    background: #fef2f2;
    color: #b91c1c;
    border-left: 4px solid #b91c1c;
  }

  .alert-success {
    background: #ecfdf5;
    color: #047857;
    border-left: 4px solid #047857;
  }

  html[data-theme="dark"] .auth-card {
    background: #1e293b;
    border-color: #334155;
  }

  html[data-theme="dark"] .auth-card h2 {
    color: #f8fafc;
  }

  html[data-theme="dark"] .modern-input {
    background: #0f172a;
    border-color: #334155;
    color: #f8fafc;
  }
</style>

<div class="auth-wrapper">
  <div class="auth-card">
    <h2>Forgot Password</h2>
    <p>Enter your account email and we will send you a password reset link.</p>

    <% if (error) { %>
      <div class="alert-modern alert-error">
        <%= error %>
      </div>
    <% } %>
    
    <% if (success) { %>
      <div class="alert-modern alert-success">
        <%= success %>
      </div>
    <% } %>

    <% if (!success) { %>
      <form method="POST" action="/forgot-password">
        <label class="form-label fw-semibold" for="email">Email Address</label>
        <input class="modern-input mb-3" id="email" type="email" name="email" required autofocus>
        <button class="modern-btn" type="submit">Send Reset Link</button>
      </form>
    <% } %>
    
    <div class="text-center mt-3">
      <a href="/login" style="color:#0f172a;font-weight:700;text-decoration:none;">Back to login</a>
    </div>
  </div>
</div>