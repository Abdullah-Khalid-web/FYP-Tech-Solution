<style>
body { background-color: #f8fafc; font-family: 'Plus Jakarta Sans', sans-serif; }
.auth-wrapper { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 7rem 1rem 2rem; }
.auth-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 20px; max-width: 460px; width: 100%; padding: 2.5rem; box-shadow: 0 20px 40px -20px rgba(15,23,42,.25); }
.auth-card h2 { color: #0f172a; font-weight: 800; margin-bottom: .5rem; }
.modern-input { width: 100%; padding: .85rem 1rem; border-radius: 12px; border: 1px solid #cbd5e1; background: #f8fafc; }
.modern-btn { width: 100%; padding: .85rem; border: 0; border-radius: 12px; background: #0f172a; color: #fff; font-weight: 700; }
.alert-modern { border-radius: 10px; padding: 1rem; margin-bottom: 1rem; background: #fef2f2; color: #b91c1c; }
html[data-theme="dark"] .auth-card { background: #1e293b; border-color: #334155; }
html[data-theme="dark"] .auth-card h2 { color: #f8fafc; }
html[data-theme="dark"] .modern-input { background: #0f172a; border-color: #334155; color: #f8fafc; }
</style>

<div class="auth-wrapper">
  <div class="auth-card">
    <h2>Reset Password</h2>
    <% if (error) { %><div class="alert-modern"><%= error %></div><% } %>
    <form method="POST" action="/reset-password/<%= token %>">
      <label class="form-label fw-semibold" for="password">New Password</label>
      <input class="modern-input mb-3" id="password" type="password" name="password" minlength="6" required autofocus>
      <label class="form-label fw-semibold" for="confirmPassword">Confirm Password</label>
      <input class="modern-input mb-3" id="confirmPassword" type="password" name="confirmPassword" minlength="6" required>
      <button class="modern-btn" type="submit">Update Password</button>
    </form>
  </div>
</div>
