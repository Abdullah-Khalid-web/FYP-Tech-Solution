<style>
  body {
    background-color: #f8fafc;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .auth-wrapper {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7rem 1rem 2rem;
  }

  .auth-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    max-width: 460px;
    width: 100%;
    padding: 2.5rem;
    box-shadow: 0 20px 40px -20px rgba(15, 23, 42, .25);
  }

  .auth-card h2 {
    color: #0f172a;
    font-weight: 800;
    margin-bottom: .5rem;
  }

  .auth-card p {
    color: #64748b;
  }

  .modern-input {
    width: 100%;
    padding: .85rem 1rem;
    border-radius: 12px;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
    transition: all 0.3s ease;
  }

  .modern-input:focus {
    outline: none;
    border-color: #0f172a;
    box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.1);
  }

  .modern-btn {
    width: 100%;
    padding: .85rem;
    border: 0;
    border-radius: 12px;
    background: #0f172a;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .modern-btn:hover {
    background: #1e293b;
  }

  .alert-modern {
    border-radius: 10px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .alert-error {
    background: #fef2f2;
    color: #b91c1c;
    border-left: 4px solid #b91c1c;
  }

  .alert-success {
    background: #ecfdf5;
    color: #047857;
    border-left: 4px solid #047857;
  }

  .password-requirements {
    font-size: 12px;
    color: #64748b;
    margin-top: 8px;
  }

  html[data-theme="dark"] .auth-card {
    background: #1e293b;
    border-color: #334155;
  }

  html[data-theme="dark"] .auth-card h2 {
    color: #f8fafc;
  }

  html[data-theme="dark"] .modern-input {
    background: #0f172a;
    border-color: #334155;
    color: #f8fafc;
  }
</style>

<div class="auth-wrapper">
  <div class="auth-card">
    <% if (error) { %>
      <div class="alert-modern alert-error">
        <%= error %>
      </div>
    <% } %>

    <% if (valid === true) { %>
      <h2>Create New Password</h2>
      <p>Please enter your new password below.</p>

      <form method="POST" action="/reset-password/<%= token %>">
        <div class="mb-3">
          <label class="form-label fw-semibold" for="password">New Password</label>
          <input class="modern-input" id="password" type="password" name="password" required>
          <div class="password-requirements">
            ✓ Password must be at least 6 characters long
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold" for="confirmPassword">Confirm New Password</label>
          <input class="modern-input" id="confirmPassword" type="password" name="confirmPassword" required>
        </div>

        <button class="modern-btn" type="submit">Reset Password</button>
      </form>

      <div class="text-center mt-3">
        <a href="/login" style="color:#0f172a;font-weight:700;text-decoration:none;">Back to Login</a>
      </div>
    <% } else if (valid === false) { %>
      <div class="alert-modern alert-error">
        <%= error || 'This password reset link is invalid or has expired.' %>
      </div>
      <div class="text-center mt-3">
        <a href="/forgot-password" style="color:#0f172a;font-weight:700;text-decoration:none;">Request New Reset Link</a>
      </div>
    <% } %>
  </div>
</div>

<script>
  // Client-side password validation
  const password = document.getElementById('password');
  const confirmPassword = document.getElementById('confirmPassword');

  if (password && confirmPassword) {
    function validatePasswordMatch() {
      if (password.value !== confirmPassword.value) {
        confirmPassword.setCustomValidity("Passwords don't match");
      } else {
        confirmPassword.setCustomValidity('');
      }
    }

    password.addEventListener('change', validatePasswordMatch);
    confirmPassword.addEventListener('keyup', validatePasswordMatch);
  }
</script>