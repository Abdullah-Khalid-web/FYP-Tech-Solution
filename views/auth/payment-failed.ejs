<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Failed - Manage Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        .failed-card {
            background: white;
            border-radius: 20px;
            padding: 40px 30px;
            text-align: center;
            max-width: 520px;
            width: min(100%, 520px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .failed-icon {
            width: 80px;
            height: 80px;
            background: #ef4444;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .failed-icon i {
            font-size: 40px;
            color: white;
        }

        .alert {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            max-width: 420px;
            margin: 0 auto;
        }

        .btn-custom {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 14px 28px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            margin-top: 20px;
            transition: transform 0.3s, box-shadow 0.3s;
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.25);
        }
    </style>
</head>

<body>
    <div class="container d-flex min-vh-100 min-vw-100 align-items-center justify-content-center">
        <div class="failed-card">
            <div class="failed-icon">
                <i class="fas fa-times"></i>
            </div>
            <h2 class="mb-3">Payment Failed</h2>
            <p class="text-muted mb-4">We couldn't process your payment. Please try again.</p>
            <a href="/register" class="btn-custom">
                <i class="fas fa-arrow-left me-2"></i> Back to Registration
            </a>
        </div>
    </div>
</body>

</html>