<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Your Shop | <%= typeof shop !=='undefined' && shop ? shop.name : 'Manage Hub' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

        body {
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
        }

        .split-layout {
            display: flex;
            min-height: 100vh;
        }

        .form-panel {
            background-color: #ffffff;
            padding: 4rem 3rem;
            max-width: 850px;
            margin: 4rem auto;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
        }

        html[data-theme="dark"] .form-panel {
            background-color: #1e293b;
            border-color: #334155;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .form-header {
            margin-bottom: 3rem;
        }

        .form-header h2 {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            color: #0f172a;
            font-size: 2.2rem;
            margin-bottom: 0.5rem;
        }

        .form-header p {
            color: #64748b;
            font-size: 1rem;
        }

        .form-section {
            margin-bottom: 2.5rem;
        }

        .section-title {
            font-family: 'Outfit', sans-serif;
            font-size: 1.4rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #f1f5f9;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title i {
            color: #0ea5e9;
        }

        .modern-label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
            display: block;
        }

        .modern-input {
            width: 100%;
            padding: 0.8rem 1rem;
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            background: #ffffff;
            color: #0f172a;
            font-size: 1rem;
            transition: all 0.2s ease;
        }

        .modern-input:focus {
            outline: none;
            border-color: #0ea5e9;
            box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
        }

        .price-preview-box {
            border-radius: 10px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 1.5rem;
            height: 100%;
        }

        .premium-btn {
            width: 100%;
            padding: 1.1rem;
            background: #0f172a;
            color: #ffffff;
            border-radius: 12px;
            border: none;
            font-weight: 600;
            font-size: 1.1rem;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(15, 23, 42, 0.2);
            margin-top: 1rem;
        }

        .premium-btn:hover {
            background: #0ea5e9;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(14, 165, 233, 0.3);
        }

        .premium-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .alert-modern {
            border-radius: 12px;
            border: none;
            padding: 1rem 1.2rem;
            margin-bottom: 2rem;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .alert-error {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .alert-success {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        html[data-theme="dark"] body {
            background-color: #0f172a;
            color: #f8fafc;
        }

        html[data-theme="dark"] .form-header h2 {
            color: #f8fafc;
        }

        html[data-theme="dark"] .form-header p,
        html[data-theme="dark"] .section-title span,
        html[data-theme="dark"] .text-muted {
            color: #94a3b8 !important;
        }

        html[data-theme="dark"] .section-title {
            color: #f8fafc;
            border-bottom-color: #334155;
        }

        html[data-theme="dark"] .modern-label {
            color: #cbd5e1;
        }

        html[data-theme="dark"] .modern-input {
            background-color: #0f172a;
            border-color: #334155;
            color: #f8fafc;
        }

        html[data-theme="dark"] .modern-input:focus {
            background-color: #1e293b;
            border-color: #0ea5e9;
        }

        html[data-theme="dark"] .price-preview-box {
            background: #1e293b;
            border-color: #334155;
        }

        html[data-theme="dark"] .price-preview-box .border-bottom {
            border-bottom-color: #334155 !important;
        }

        html[data-theme="dark"] .price-preview-box strong {
            color: #f8fafc !important;
        }

        html[data-theme="dark"] .price-preview-box #calculatedPrice,
        html[data-theme="dark"] .price-preview-box #savings {
            color: #0ea5e9 !important;
        }

        @media (max-width: 991.98px) {
            .form-panel {
                margin: 2rem 1rem;
                padding: 3rem 1.5rem;
            }
        }
        
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }
        
        .loading-overlay.active {
            display: flex;
        }
        
        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid #f3f3f3;
            border-top: 3px solid #0ea5e9;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        .loading-text {
            color: white;
            margin-top: 15px;
            font-size: 1rem;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        });
    </script>
</head>
<body>

<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text">Processing payment...</div>
</div>

<div class="split-layout">
    <div class="form-panel">
        <div class="form-header">
            <h2>Create Your Account</h2>
            <p>Fill out the information below to set up your store and get started.</p>
        </div>

        <% if (error) { %>
        <div class="alert-modern alert-error">
            <i class="fas fa-exclamation-circle fs-5"></i>
            <%= error %>
        </div>
        <% } %>
        <% if (success) { %>
        <div class="alert-modern alert-success">
            <i class="fas fa-check-circle fs-5"></i>
            <%= success %>
        </div>
        <% } %>

        <form action="/register" method="POST" enctype="multipart/form-data" id="registrationForm">

            <!-- Step 1: Shop Information -->
            <div class="form-section">
                <div class="section-title">
                    <i class="fas fa-store"></i> Shop Information
                </div>
                <div class="row g-3">
                    <div class="col-md-12">
                        <label for="shopName" class="modern-label">Shop Name *</label>
                        <input type="text" class="modern-input" id="shopName" name="shopName" required placeholder="e.g., My Retail Store">
                    </div>
                    <div class="col-md-6">
                        <label for="email" class="modern-label">Shop Email *</label>
                        <input type="email" class="modern-input" id="email" name="email" required placeholder="shop@example.com">
                    </div>
                    <div class="col-md-6">
                        <label for="phone" class="modern-label">Shop Phone</label>
                        <input type="tel" class="modern-input" id="phone" name="phone" placeholder="+92 300 0000000">
                    </div>
                    <div class="col-md-12">
                        <label for="address" class="modern-label">Physical Address</label>
                        <input type="text" class="modern-input" id="address" name="address" placeholder="Full address">
                    </div>
                    <div class="col-md-6">
                        <label for="currency" class="modern-label">Primary Currency</label>
                        <select class="modern-input form-select" id="currency" name="currency">
                            <option value="PKR">PKR (Pakistani Rupee)</option>
                            <option value="USD">USD (US Dollar)</option>
                            <option value="EUR">EUR (Euro)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="logo" class="modern-label">Shop Logo (Optional)</label>
                        <input type="file" class="modern-input" id="logo" name="logo" accept="image/*">
                    </div>
                </div>
            </div>

            <!-- Step 2: Subscription Plan -->
            <div class="form-section">
                <div class="section-title">
                    <i class="fas fa-gem"></i> Subscription Plan
                </div>
                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="mb-3">
                            <label for="plan" class="modern-label">Select Plan *</label>
                            <select class="modern-input form-select" id="plan" name="plan" required>
                                <option value="">Choose a plan...</option>
                                <% plans.forEach(p=> { %>
                                    <option value="<%= p.name %>"
                                        data-monthly="<%= p.monthly_price %>"
                                        data-quarterly="<%= p.quarterly_price %>"
                                        data-yearly="<%= p.yearly_price %>">
                                        <%= p.name.toUpperCase() %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div>
                            <label class="modern-label">Billing Cycle *</label>
                            <div class="d-flex flex-column gap-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="subscriptionDuration" value="monthly" id="monthly" checked>
                                    <label class="form-check-label" for="monthly">Monthly</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="subscriptionDuration" value="quarterly" id="quarterly">
                                    <label class="form-check-label" for="quarterly">Quarterly</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="subscriptionDuration" value="yearly" id="yearly">
                                    <label class="form-check-label" for="yearly">Yearly (Save 20%)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="price-preview-box">
                            <h6 class="mb-3" style="font-weight: 700; color: #475569;">Price Summary</h6>
                            <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                                <span class="text-muted">Plan Selected:</span>
                                <strong id="selectedPlan" style="color: #0f172a;">-</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                                <span class="text-muted">Billing Cycle:</span>
                                <strong id="selectedDuration" style="color: #0f172a;">-</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                                <span class="text-muted">Total Savings:</span>
                                <strong id="savings" style="color: #10b981;">PKR 0</strong>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <span style="font-weight: 600; color: #0f172a; font-size: 1.1rem;">Total Due:</span>
                                <strong id="calculatedPrice" style="color: #0ea5e9; font-size: 1.2rem;">PKR 0</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>



            <!-- Step 3: Owner Credentials -->
            <div class="form-section">
                <div class="section-title">
                    <i class="fas fa-user-shield"></i> Owner Credentials
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="ownerName" class="modern-label">Full Name *</label>
                        <input type="text" class="modern-input" id="ownerName" name="ownerName" required placeholder="John Doe">
                    </div>
                    <div class="col-md-6">
                        <label for="cnic" class="modern-label">CNIC / ID Number *</label>
                        <input type="text" class="modern-input" id="cnic" name="cnic" required placeholder="00000-0000000-0">
                    </div>
                    <div class="col-md-12">
                        <label for="ownerEmail" class="modern-label">Personal Email (Login ID) *</label>
                        <input type="email" class="modern-input" id="ownerEmail" name="ownerEmail" required placeholder="owner@example.com">
                    </div>
                    <div class="col-md-6">
                        <label for="ownerphone" class="modern-label">Personal Phone *</label>
                        <input type="text" class="modern-input" id="ownerphone" name="ownerphone" required placeholder="+92 300 0000000">
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label for="ownerPassword" class="modern-label">Password *</label>
                        <input type="password" class="modern-input" id="ownerPassword" name="ownerPassword" required minlength="6" placeholder="Create a strong password">
                    </div>
                    <div class="col-md-6">
                        <label for="confirmPassword" class="modern-label">Confirm Password *</label>
                        <input type="password" class="modern-input" id="confirmPassword" name="confirmPassword" required placeholder="Repeat password">
                    </div>
                </div>
            </div>

            <!-- Step 4: Payment Details -->
            <div class="form-section">
                <div class="section-title">
                    <i class="fas fa-credit-card"></i> Payment Information
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="paymentMethod" class="modern-label">Payment Method *</label>
                        <select class="modern-input form-select" id="paymentMethod" name="paymentMethod" required>
                            <option value="">Select Method...</option>
                            <option value="stripe">💳 Credit/Debit Card (Stripe)</option>
                            <option value="bank_transfer">🏦 Bank Transfer</option>
                            <option value="jazzcash">📱 JazzCash</option>
                            <option value="easypaisa">📱 EasyPaisa</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="paymentDetails" class="modern-label">Transaction Reference ID</label>
                        <input type="text" class="modern-input" id="paymentDetails" name="paymentDetails" placeholder="e.g. TID-123456789">
                    </div>
                </div>
            </div>

            <button type="submit" class="premium-btn" id="submitBtn">Create Your Shop Account</button>

            <div class="text-center mt-4">
                <span style="color: #64748b;">Already have an account?</span>
                <a href="/login" style="color: #0ea5e9; font-weight: 700; text-decoration: none;">Sign in here</a>
            </div>
        </form>
    </div>
</div>

<script>
    // Price Calculation Logic
    const planSelect = document.getElementById('plan');
    const durationRadios = document.querySelectorAll('input[name="subscriptionDuration"]');
    const priceSpan = document.getElementById('calculatedPrice');
    const savingsSpan = document.getElementById('savings');
    const planSpan = document.getElementById('selectedPlan');
    const durationSpan = document.getElementById('selectedDuration');

    function updatePrice() {
        const selectedOption = planSelect.options[planSelect.selectedIndex];
        if (!selectedOption || !selectedOption.dataset.monthly) {
            planSpan.textContent = "-";
            priceSpan.textContent = "PKR 0";
            return;
        }

        const monthly = parseFloat(selectedOption.dataset.monthly);
        const quarterly = parseFloat(selectedOption.dataset.quarterly);
        const yearly = parseFloat(selectedOption.dataset.yearly);
        const duration = document.querySelector('input[name="subscriptionDuration"]:checked').value;

        let price = monthly;
        let savings = 0;

        if (duration === 'quarterly') {
            price = quarterly;
            savings = (monthly * 3) - quarterly;
        } else if (duration === 'yearly') {
            price = yearly;
            savings = (monthly * 12) - yearly;
        }

        planSpan.textContent = selectedOption.text;
        durationSpan.textContent = duration.charAt(0).toUpperCase() + duration.slice(1);
        priceSpan.textContent = `PKR ${price.toLocaleString()}`;
        savingsSpan.textContent = `PKR ${savings.toLocaleString()}`;
        return price;
    }

    planSelect.addEventListener('change', updatePrice);
    durationRadios.forEach(r => r.addEventListener('change', updatePrice));
</script>

<!-- Stripe JS -->
<script src="https://js.stripe.com/v3/"></script>

<script>
    let stripe = null;
    let elements = null;
    let cardElement = null;
    
    const stripePublishableKey = '<%= stripePublishableKey %>';
    if (stripePublishableKey && stripePublishableKey !== 'undefined' && stripePublishableKey !== '') {
        stripe = Stripe(stripePublishableKey);
        console.log('Stripe initialized');
    }

    document.getElementById('paymentMethod').addEventListener('change', function() {
        const paymentMethodDiv = document.getElementById('stripePaymentElement');
        if (this.value === 'stripe' && stripe) {
            if (!paymentMethodDiv) {
                const formContainer = document.createElement('div');
                formContainer.id = 'stripePaymentElement';
                formContainer.className = 'mt-3';
                formContainer.innerHTML = `
                    <div class="card p-3">
                        <label class="modern-label">Card Details</label>
                        <div id="card-element" style="padding: 12px; border: 1px solid #cbd5e1; border-radius: 10px;"></div>
                        <div id="card-errors" class="text-danger mt-2" style="font-size: 0.85rem;"></div>
                        <div class="mt-2">
                            <small class="text-muted">Test card: 4242 4242 4242 4242 (any future expiry, any CVC)</small>
                        </div>
                    </div>
                `;
                const submitBtn = document.querySelector('button[type="submit"]');
                document.querySelector('form').insertBefore(formContainer, submitBtn);
                
                elements = stripe.elements();
                const style = {
                    base: {
                        color: '#32325d',
                        fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
                        fontSmoothing: 'antialiased',
                        fontSize: '16px',
                        '::placeholder': { color: '#aab7c4' }
                    },
                    invalid: { color: '#fa755a', iconColor: '#fa755a' }
                };
                
                if (document.documentElement.getAttribute('data-theme') === 'dark') {
                    style.base.color = '#f8fafc';
                    style.base.backgroundColor = '#0f172a';
                }
                
                cardElement = elements.create('card', { style: style, hidePostalCode: true });
                cardElement.mount('#card-element');
                
                cardElement.on('change', function(event) {
                    const displayError = document.getElementById('card-errors');
                    if (event.error) {
                        displayError.textContent = event.error.message;
                    } else {
                        displayError.textContent = '';
                    }
                });
            }
        } else {
            if (paymentMethodDiv) {
                paymentMethodDiv.remove();
                cardElement = null;
            }
        }
    });

    document.getElementById('registrationForm').addEventListener('submit', async function(e) {
        const paymentMethod = document.getElementById('paymentMethod').value;
        const submitBtn = document.getElementById('submitBtn');
        const loadingOverlay = document.getElementById('loadingOverlay');
        
        if (paymentMethod === 'stripe') {
            e.preventDefault();
            
            if (!stripe || !cardElement) {
                alert('Stripe is not initialized properly. Please refresh the page and try again.');
                return;
            }
            
            const price = updatePrice();
            if (!price || price <= 0) {
                alert('Please select a valid plan');
                return;
            }
            
            loadingOverlay.classList.add('active');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Processing Payment...';
            
            try {
                const formData = new FormData(this);
                const shopData = {
                    shopName: formData.get('shopName'),
                    ownerEmail: formData.get('ownerEmail')
                };
                
// In register.ejs, replace the fetch section with this:

const response = await fetch('/create-payment-intent', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
        amount: price,
        planName: planSelect.value,
        duration: document.querySelector('input[name="subscriptionDuration"]:checked').value,
        shopData: shopData
    })
});

// Log the response status
console.log('Response status:', response.status);
console.log('Response headers:', response.headers);

const contentType = response.headers.get("content-type");
if (!contentType || !contentType.includes("application/json")) {
    const text = await response.text();
    console.error('Non-JSON response:', text);
    // Log the first 500 characters to see what HTML it is
    throw new Error(`Server returned ${contentType || 'unknown content type'}. First 200 chars: ${text.substring(0, 200)}`);
}

                
                const data = await response.json();
                if (!data.success) throw new Error(data.message);
                
                const result = await stripe.confirmCardPayment(data.clientSecret, {
                    payment_method: {
                        card: cardElement,
                        billing_details: {
                            name: document.getElementById('ownerName').value,
                            email: document.getElementById('ownerEmail').value
                        }
                    }
                });
                
                if (result.error) throw new Error(result.error.message);
                
                if (result.paymentIntent && result.paymentIntent.status === 'succeeded') {
                    const hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'paymentIntentId';
                    hiddenInput.value = result.paymentIntent.id;
                    this.appendChild(hiddenInput);
                    this.submit();
                } else {
                    throw new Error('Payment not completed');
                }
            } catch (error) {
                alert('Payment failed: ' + error.message);
                loadingOverlay.classList.remove('active');
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Create Your Shop Account';
            }
        }
    });
    
    updatePrice();
</script>

</body>
</html>