        // Production report
        // Production report
        function renderProductionReport(data) {
            // Update summary
            document.getElementById('totalProductsSold').textContent = data.summary.totalProductsSold;
            document.getElementById('totalExpectedUsage').textContent = data.summary.totalExpectedUsage.toFixed(2);
            document.getElementById('totalActualUsage').textContent = data.summary.totalActualUsage.toFixed(2);
            document.getElementById('totalVariance').textContent = data.summary.totalVariance.toFixed(2);
            document.getElementById('totalCostImpact').textContent = shopData.currency + ' ' + Math.abs(data.summary.totalCostImpact).toFixed(2);
            document.getElementById('possibleTheftCases').textContent = data.summary.possibleTheftCases;
            document.getElementById('lowStockIngredients').textContent = data.summary.lowStockIngredients;
            document.getElementById('variancePercentage').textContent = data.summary.variancePercentage.toFixed(1) + '%';

            // Show/hide theft alert
            const theftAlert = document.getElementById('theftAlert');
            const theftDetectionSection = document.getElementById('theftDetectionSection');
            
            if (data.summary.possibleTheftCases > 0) {
                theftAlert.style.display = 'block';
                theftDetectionSection.style.display = 'block';
                document.getElementById('theftAlertMessage').textContent = 
                    `Warning: ${data.summary.possibleTheftCases} possible theft cases detected. Missing raw materials worth ${shopData.currency} ${Math.abs(data.summary.totalCostImpact).toFixed(2)}`;
            } else {
                theftAlert.style.display = 'none';
                theftDetectionSection.style.display = 'none';
            }

            // Usage Comparison Chart
            if (charts.usageComparisonChart) charts.usageComparisonChart.destroy();
            if (data.expectedUsage.length > 0) {
                const usageCtx = document.getElementById('usageComparisonChart').getContext('2d');
                const topItems = data.expectedUsage.slice(0, 10);
                
                charts.usageComparisonChart = new Chart(usageCtx, {
                    type: 'bar',
                    data: {
                        labels: topItems.map(item => item.ingredient.substring(0, 15)),
                        datasets: [{
                            label: 'Expected Usage',
                            data: topItems.map(item => item.expected_usage),
                            backgroundColor: '#4e73df'
                        }, {
                            label: 'Actual Usage',
                            data: topItems.map(item => item.actual_usage),
                            backgroundColor: '#1cc88a'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Quantity'
                                }
                            }
                        }
                    }
                });
            }

            // Variance Chart
            if (charts.varianceChart) charts.varianceChart.destroy();
            if (data.varianceAnalysis.length > 0) {
                const varianceCtx = document.getElementById('varianceChart').getContext('2d');
                const topVariances = data.varianceAnalysis.slice(0, 10);
                
                charts.varianceChart = new Chart(varianceCtx, {
                    type: 'bar',
                    data: {
                        labels: topVariances.map(item => item.ingredient.substring(0, 15)),
                        datasets: [{
                            label: 'Variance %',
                            data: topVariances.map(item => item.variance_percentage),
                            backgroundColor: topVariances.map(item => 
                                item.variance_percentage > 20 ? '#e74a3b' : 
                                item.variance_percentage > 10 ? '#f6c23e' : 
                                item.variance_percentage < -20 ? '#dc3545' : 
                                item.variance_percentage < -10 ? '#fd7e14' : '#1cc88a'
                            )
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Variance %'
                                }
                            }
                        }
                    }
                });
            }

            // Usage Analysis Table
            const usageHtml = data.expectedUsage.map(item => `
                <tr class="${item.status === 'possible_theft' ? 'table-danger' : item.status === 'excess_usage' ? 'table-warning' : ''}">
                    <td>${escapeHtml(item.product)}</td>
                    <td>${escapeHtml(item.ingredient)}</td>
                    <td>${item.units_sold}</td>
                    <td>${item.expected_usage.toFixed(2)}</td>
                    <td>${item.actual_usage.toFixed(2)}</td>
                    <td class="${item.variance > 0 ? 'text-success' : 'text-danger'}">
                        ${item.variance.toFixed(2)}
                    </td>
                    <td class="${Math.abs(item.variance_percentage) > 20 ? 'text-danger' : Math.abs(item.variance_percentage) > 10 ? 'text-warning' : 'text-success'}">
                        ${item.variance_percentage.toFixed(1)}%
                    </td>
                    <td>
                        <span class="badge ${item.status === 'normal' ? 'bg-success' : item.status === 'excess_usage' ? 'bg-warning' : 'bg-danger'}">
                            ${item.status.replace('_', ' ')}
                        </span>
                    </td>
                    <td class="${item.variance > 0 ? 'text-success' : 'text-danger'}">
                        ${shopData.currency} ${(item.variance * item.cost || 0).toFixed(2)}
                    </td>
                </tr>
            `).join('');
            document.querySelector('#usageAnalysisTable tbody').innerHTML = usageHtml || '<tr><td colspan="9" class="text-center">No usage data found</td></tr>';

            // Theft Detection Table
            const theftHtml = data.theftDetection.map(item => `
                <tr>
                    <td>${escapeHtml(item.ingredient)}</td>
                    <td>${escapeHtml(item.product)}</td>
                    <td>${item.expected_usage.toFixed(2)}</td>
                    <td>${item.actual_usage.toFixed(2)}</td>
