                </tr>
            `).join('');
            document.querySelector('#ingredientMovementsTable').innerHTML = movementsHtml || '<tr><td colspan="6" class="text-center">No movements found</td></tr>';
        }

                
        // Export report
        async function exportReport(reportType) {
            try {
                const response = await fetch(`/reports/download/${reportType}?fromDate=${document.getElementById('fromDate').value}&toDate=${document.getElementById('toDate').value}`);
                
                if (response.ok) {
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `${reportType}-report-${new Date().toISOString().slice(0,10)}.xlsx`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                } else {
                    toastr.error('Failed to export report');
                }
            } catch (error) {
                console.error('Error exporting report:', error);
                toastr.error('Error exporting report');
            }
        }

        // View individual ledgers
        async function viewProductLedger(productId) {
            try {
                const response = await fetch(`/products/${productId}/ledger`);
                const data = await response.json();
                
                if (data.success) {
                    // Open ledger in modal or new tab
                    const ledgerWindow = window.open('', '_blank');
                    ledgerWindow.document.write(`
                        <html>
                        <head>
                            <title>Product Ledger</title>
                            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
                            <style>
                                body { padding: 20px; }
                                .table th { background: #f8f9fc; }
                            </style>
                        </head>
                        <body>
                            <h3>Stock Ledger: ${escapeHtml(data.product.name)}</h3>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Batch</th>
                                            <th>Quantity</th>
                                            <th>Buying Price</th>
                                            <th>Selling Price</th>
                                            <th>Total Value</th>
                                            <th>Supplier</th>
                                            <th>Received By</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${data.ledger.map(entry => `
                                            <tr>
                                                <td>${new Date(entry.date_added).toLocaleDateString()}</td>
                                                <td>${escapeHtml(entry.batch_number || 'N/A')}</td>
                                                <td>${entry.quantity}</td>
                                                <td>${shopData.currency} ${Number(entry.buying_price).toFixed(2)}</td>
                                                <td>${shopData.currency} ${Number(entry.selling_price).toFixed(2)}</td>
                                                <td>${shopData.currency} ${Number(entry.total_value).toFixed(2)}</td>
                                                <td>${escapeHtml(entry.supplier_name || 'N/A')}</td>
                                                <td>${escapeHtml(entry.received_by || 'System')}</td>
                                            </tr>
                                        `).join('')}
                                    </tbody>
                                </table>
                            </div>
                            <button class="btn btn-primary mt-3" onclick="window.print()">Print</button>
                        </body>
                        </html>
                    `);
