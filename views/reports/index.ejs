    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/exceljs/4.4.0/exceljs.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <script>
        // Toastr configuration
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };

        // Global variables
        let charts = {};
        let currentReport = 'overview';
        let reportData = {};

        // Update datetime
        function updateDateTime() {
            const now = new Date();
            const options = { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            };
            document.getElementById('datetime').textContent = now.toLocaleDateString('en-IN', options);
        }
        setInterval(updateDateTime, 60000);
        updateDateTime();

        // Show report section
        function showReport(reportType) {
            currentReport = reportType;
            
            // Update active tab
            document.querySelectorAll('#reportTabs .nav-link').forEach(link => {
                link.classList.remove('active');
            });
            document.querySelector(`#reportTabs a[onclick="showReport('${reportType}')"]`).classList.add('active');
            
            // Show active section
            document.querySelectorAll('.report-section').forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById(reportType + 'Report').classList.add('active');
            
            // Load report data
            loadReportData(reportType);
        }

        // Apply filters
        // Apply filters
        function applyFilters() {
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;
            const reportType = document.getElementById('reportType').value;
            
            // Update URL without reloading page
            const url = new URL(window.location);
            url.searchParams.set('fromDate', fromDate);
            url.searchParams.set('toDate', toDate);
            url.searchParams.set('type', reportType);
            window.history.pushState({}, '', url);
            
            // Reload the current report
            loadReportData(currentReport);
        }

        function resetFilters() {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
            
            document.getElementById('fromDate').value = firstDay.toISOString().slice(0, 10);
            document.getElementById('toDate').value = today.toISOString().slice(0, 10);
            document.getElementById('reportType').value = 'monthly';
        }

        // Load report data
        async function loadReportData(reportType) {
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;
            const type = document.getElementById('reportType').value;

            try {
                const response = await fetch(`/reports/${reportType}?fromDate=${fromDate}&toDate=${toDate}&type=${type}`);
                const data = await response.json();

                if (data.success) {
                    reportData[reportType] = data;
                    renderReport(reportType, data);
                } else {
                    toastr.error(data.message || 'Failed to load report data');
                }
            } catch (error) {
                console.error('Error loading report:', error);
                toastr.error('Error loading report data');
            }
        }

        // Render report
        function renderReport(reportType, data) {
            switch(reportType) {
                case 'overview':
                    renderOverview(data);
                    break;
                case 'bills':
                    renderBillsReport(data);
                    break;
                case 'products':
                    renderProductsReport(data);
                    break;
                case 'suppliers':
                    renderSuppliersReport(data);
                    break;
                case 'employees':
                    renderEmployeesReport(data);
                    break;
                case 'raw-materials':
                    renderRawMaterialsReport(data);
                    break;
                case 'production':
                    renderProductionReport(data);
                    break;
            }
        }

        // Overview report
        function renderOverview(data) {
            // Revenue Trend Chart
            if (charts.revenueChart) charts.revenueChart.destroy();
            const revenueCtx = document.getElementById('revenueChart').getContext('2d');
            charts.revenueChart = new Chart(revenueCtx, {
                type: 'line',
                data: {
                    labels: data.revenueTrend.map(item => item.period),
                    datasets: [{
                        label: 'Revenue',
                        data: data.revenueTrend.map(item => item.revenue || 0),
                        borderColor: '#4e73df',
                        backgroundColor: 'rgba(78, 115, 223, 0.1)',
                        tension: 0.1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return shopData.currency + ' ' + value;
                                }
                            }
                        }
                    }
                }
            });

            // Payment Methods Chart
            if (charts.paymentMethodChart) charts.paymentMethodChart.destroy();
            const paymentCtx = document.getElementById('paymentMethodChart').getContext('2d');
            charts.paymentMethodChart = new Chart(paymentCtx, {
                type: 'doughnut',
                data: {
                    labels: data.paymentMethods ? data.paymentMethods.map(item => item.method) : [],
                    datasets: [{
                        data: data.paymentMethods ? data.paymentMethods.map(item => item.totalAmount || 0) : [],
                        backgroundColor: [
                            '#4e73df',
                            '#1cc88a',
                            '#f6c23e',
                            '#e74a3b',
                            '#36b9cc'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

            // Top Products
            const topProductsHtml = data.topProducts ? data.topProducts.map(product => `
                <div class="summary-item">
                    <span>${escapeHtml(product.name)}</span>
                    <span>${shopData.currency} ${Number(product.revenue || 0).toFixed(2)}</span>
                </div>
            `).join('') : '<p class="text-muted">No data available</p>';
            document.getElementById('topProductsList').innerHTML = topProductsHtml;

            // Stock Alerts
            const stockAlertsHtml = data.stockAlerts ? data.stockAlerts.map(alert => `
                <div class="summary-item">
                    <span>${escapeHtml(alert.name)}</span>
                    <span class="badge ${alert.status === 'Low' ? 'bg-danger' : 'bg-warning'}">
                        ${alert.current_quantity} / ${alert.min_stock_level}
                    </span>
                </div>
            `).join('') : '<p class="text-muted">No stock alerts</p>';
            document.getElementById('stockAlertsList').innerHTML = stockAlertsHtml;
        }

        // Bills report
        function renderBillsReport(data) {
            // Update summary
            document.getElementById('totalBillsCount').textContent = data.summary.totalBills;
            document.getElementById('totalRevenue').textContent = shopData.currency + ' ' + Number(data.summary.totalRevenue).toFixed(2);
            document.getElementById('averageBill').textContent = shopData.currency + ' ' + (data.summary.totalBills > 0 ? (data.summary.totalRevenue / data.summary.totalBills).toFixed(2) : '0.00');
            document.getElementById('totalDue').textContent = shopData.currency + ' ' + Number(data.summary.totalDue).toFixed(2);

            // Bills Trend Chart
            if (charts.billsTrendChart) charts.billsTrendChart.destroy();
            const trendCtx = document.getElementById('billsTrendChart').getContext('2d');
            charts.billsTrendChart = new Chart(trendCtx, {
                type: 'bar',
                data: {
                    labels: data.billsByDate.map(item => item.period),
                    datasets: [{
                        label: 'Revenue',
                        data: data.billsByDate.map(item => item.totalRevenue || 0),
                        backgroundColor: '#4e73df'
                    }, {
                        label: 'Bills',
                        data: data.billsByDate.map(item => item.billCount || 0),
                        backgroundColor: '#1cc88a',
                        type: 'line',
                        yAxisID: 'y1'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Revenue'
                            },
                            ticks: {
                                callback: function(value) {
                                    return shopData.currency + ' ' + value;
                                }
                            }
                        },
                        y1: {
                            beginAtZero: true,
                            position: 'right',
                            title: {
                                display: true,
                                text: 'Number of Bills'
                            }
                        }
                    }
                }
            });

            // Payment Methods Chart
            if (charts.billsPaymentChart) charts.billsPaymentChart.destroy();
            const billsPaymentCtx = document.getElementById('billsPaymentChart').getContext('2d');
            charts.billsPaymentChart = new Chart(billsPaymentCtx, {
                type: 'pie',
                data: {
                    labels: data.paymentMethods.map(item => item.method),
                    datasets: [{
                        data: data.paymentMethods.map(item => item.totalAmount || 0),
                        backgroundColor: [
                            '#4e73df',
                            '#1cc88a',
                            '#f6c23e',
                            '#e74a3b',
                            '#36b9cc'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

            // Bills Table
            const billsHtml = data.bills.map(bill => `
                <tr>
                    <td>${escapeHtml(bill.bill_number)}</td>
                    <td>${escapeHtml(bill.customer_name || 'Walk-in')}</td>
                    <td>${escapeHtml(bill.customer_phone || 'N/A')}</td>
                    <td>${shopData.currency} ${Number(bill.total_amount).toFixed(2)}</td>
                    <td>${shopData.currency} ${Number(bill.paid_amount).toFixed(2)}</td>
                    <td class="${bill.due_amount > 0 ? 'text-danger' : 'text-success'}">
                        ${shopData.currency} ${Number(bill.due_amount).toFixed(2)}
                    </td>
                    <td><span class="badge bg-info">${escapeHtml(bill.payment_method || 'Cash')}</span></td>
                    <td>${bill.bill_date}</td>
                    <td>${escapeHtml(bill.created_by || 'System')}</td>
                </tr>
            `).join('');
            document.querySelector('#billsTable tbody').innerHTML = billsHtml || '<tr><td colspan="9" class="text-center">No bills found</td></tr>';
        }

        // Products report
        function renderProductsReport(data) {
            // Update summary
            document.getElementById('totalProductsCount').textContent = data.summary.totalProducts;
            document.getElementById('activeProductsCount').textContent = data.products.filter(p => p.status === 'active').length;
            document.getElementById('totalStockValue').textContent = shopData.currency + ' ' + Number(data.summary.totalStockValue).toFixed(2);
            document.getElementById('lowStockCount').textContent = data.summary.lowStockCount;

            // Product Sales Chart
            if (charts.productSalesChart) charts.productSalesChart.destroy();
            if (data.productSales && data.productSales.length > 0) {
                const salesCtx = document.getElementById('productSalesChart').getContext('2d');
                charts.productSalesChart = new Chart(salesCtx, {
                    type: 'bar',
                    data: {
                        labels: data.productSales.slice(0, 10).map(item => item.name),
                        datasets: [{
                            label: 'Revenue',
                            data: data.productSales.slice(0, 10).map(item => item.total_revenue || 0),
                            backgroundColor: '#4e73df'
                        }, {
                            label: 'Quantity Sold',
                            data: data.productSales.slice(0, 10).map(item => item.total_quantity || 0),
                            backgroundColor: '#1cc88a',
                            type: 'line',
                            yAxisID: 'y1'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Revenue'
                                },
                                ticks: {
                                    callback: function(value) {
                                        return shopData.currency + ' ' + value;
                                    }
                                }
                            },
                            y1: {
                                beginAtZero: true,
                                position: 'right',
                                title: {
                                    display: true,
                                    text: 'Quantity'
                                }
                            }
                        }
                    }
                });
            }

            // Product Category Chart
            if (charts.productCategoryChart) charts.productCategoryChart.destroy();
            const categories = {};
            data.products.forEach(product => {
                const category = product.category || 'Uncategorized';
                categories[category] = (categories[category] || 0) + 1;
            });

            const categoryCtx = document.getElementById('productCategoryChart').getContext('2d');
            charts.productCategoryChart = new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(categories),
                    datasets: [{
                        data: Object.values(categories),
                        backgroundColor: Object.keys(categories).map((_, i) => 
                            ['#4e73df', '#1cc88a', '#f6c23e', '#e74a3b', '#36b9cc'][i % 5]
                        )
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

            // Top Selling Products
            const topSellingHtml = data.productSales.slice(0, 5).map(product => `
                <div class="summary-item">
                    <span>${escapeHtml(product.name)}</span>
                    <span>${product.total_quantity} units</span>
                    <span>${shopData.currency} ${Number(product.total_revenue).toFixed(2)}</span>
                </div>
            `).join('');
            document.getElementById('topSellingProducts').innerHTML = topSellingHtml || '<p class="text-muted">No sales data</p>';

            // Stock Movements
            const movementsHtml = data.stockMovements.slice(0, 5).map(movement => `
                <div class="summary-item">
                    <span>${escapeHtml(movement.product_name)}</span>
                    <span>${movement.quantity}</span>
                    <span>${shopData.currency} ${Number(movement.unit_price).toFixed(2)}</span>
                    <span>${movement.received_date}</span>
                </div>
            `).join('');
            document.getElementById('stockMovementsList').innerHTML = movementsHtml || '<p class="text-muted">No stock movements</p>';

            // Products Table
            const productsHtml = data.products.map(product => `
                <tr>
                    <td>
                        <strong>${escapeHtml(product.name)}</strong>
                        ${product.brand ? `<br><small class="text-muted">${escapeHtml(product.brand)}</small>` : ''}
                    </td>
