                            ${item.confidence}
                        </span>
                    </td>
                </tr>
            `).join('');
            document.querySelector('#theftDetectionTable').innerHTML = theftHtml || '<tr><td colspan="7" class="text-center">No theft cases detected</td></tr>';

            // Ingredient Movements Table
